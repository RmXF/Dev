# Main
main() {
    detect_os
    
    if [ "$OS" = "centos" ]; then
        install_dependencies_centos
        setup_database
        create_panel_files
        configure_apache_centos
        setup_monitoring
        show_info
    else
        print_color "Usa el script para Debian/Ubuntu" "$RED"
        exit 1
    fi
}

