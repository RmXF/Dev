# Configurar Apache para CentOS
configure_apache_centos() {
    print_color "Configurando Apache para CentOS..." "$BLUE"
    
    # Configuración del virtual host
    cat > /etc/httpd/conf.d/vps-panel.conf << EOF
Listen ${PANEL_PORT}

<VirtualHost *:${PANEL_PORT}>
    ServerAdmin admin@vpspanel.com
    DocumentRoot ${PANEL_DIR}
    ServerName _default_
    
    <Directory ${PANEL_DIR}>
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted
        DirectoryIndex index.php login.php dashboard.php
    </Directory>
    
    ErrorLog /var/log/httpd/vps-panel-error.log
    CustomLog /var/log/httpd/vps-panel-access.log combined
</VirtualHost>

<VirtualHost *:80>
    ServerAdmin admin@vpspanel.com
    ServerName _default_
    Redirect permanent / http://%{SERVER_NAME}:${PANEL_PORT}/
</VirtualHost>
EOF
    
    # Configurar php.ini para sesiones
    sed -i 's/session.save_path =.*/session.save_path = "\/var\/lib\/php\/session"/' /etc/php.ini
    
    # Crear directorio de sesiones
    mkdir -p /var/lib/php/session
    chown -R ${APACHE_USER}:${APACHE_GROUP} /var/lib/php/session
    
    # Configurar firewall
    systemctl start firewalld 2>/dev/null || true
    firewall-cmd --permanent --add-port=${PANEL_PORT}/tcp 2>/dev/null || true
    firewall-cmd --permanent --add-service=http 2>/dev/null || true
    firewall-cmd --reload 2>/dev/null || true
    
    # Habilitar y arrancar Apache
    systemctl enable httpd
    systemctl restart httpd
    
    print_color "Apache configurado en puerto ${PANEL_PORT}" "$GREEN"
}

# Script de monitoreo
setup_monitoring() {
    print_color "Configurando monitoreo..." "$BLUE"
    
    cat > /usr/local/bin/vps-monitor << 'EOF'
#!/bin/bash
echo "=== VPS MONITOR ==="
echo "CPU: $(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | cut -d'%' -f1)%"
echo "RAM: $(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2}')"
echo "DISK: $(df -h / | awk 'NR==2{print $5}')"
echo "UPTIME: $(uptime -p)"
EOF
    
    chmod +x /usr/local/bin/vps-monitor
    
    print_color "Monitoreo configurado" "$GREEN"
}

