    $pdo = connectDB();
    $stmt = $pdo->prepare("INSERT INTO logs (user_id, action, description, ip_address) VALUES (?, ?, ?, ?)");
    $stmt->execute([$user_id, $action, $description, $_SERVER['REMOTE_ADDR']]);
