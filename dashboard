APACHE_USER="apache"
APACHE_GROUP="apache"

print_color() {
    echo -e "${2}${1}${NC}"
}

# Detectar sistema operativo
detect_os() {
    if [ -f /etc/redhat-release ]; then
        OS="centos"
        print_color "Sistema CentOS/RHEL detectado" "$GREEN"
    elif [ -f /etc/debian_version ]; then
        OS="debian"
        print_color "Sistema Debian/Ubuntu detectado" "$GREEN"
    else
        print_color "Sistema operativo no soportado" "$RED"
        exit 1
    fi
}

# Instalar dependencias para CentOS
install_dependencies_centos() {
    print_color "Instalando dependencias para CentOS..." "$BLUE"
    
    # Habilitar EPEL
    yum install -y epel-release
    
    # Instalar paquetes
    yum install -y httpd \
                   php \
                   php-mysqlnd \
                   php-sqlite3 \
                   php-json \
                   php-mbstring \
                   php-xml \
                   php-gd \
                   curl \
                   wget \
                   git \
                   unzip \
                   net-tools \
                   firewalld \
                   fail2ban \
                   sqlite \
                   python3 \
                   python3-pip
    
    # Instalar Node.js
    curl -sL https://rpm.nodesource.com/setup_18.x | bash -
    yum install -y nodejs
    
    # Configurar Apache user
    APACHE_USER="apache"
    APACHE_GROUP="apache"
    
    print_color "Dependencias instaladas" "$GREEN"
}

# Configurar base de datos
setup_database() {
    print_color "Configurando base de datos..." "$BLUE"
    
    mkdir -p "$(dirname $DB_FILE)"
    
    cat > /tmp/init_db.sql << 'EOF'
CREATE TABLE IF NOT EXISTS users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    email VARCHAR(100),
    role VARCHAR(20) DEFAULT 'user',
    status VARCHAR(20) DEFAULT 'active',
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    last_login DATETIME,
    ssh_key TEXT,
    vps_limits VARCHAR(255)
);

CREATE TABLE IF NOT EXISTS vps_instances (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    instance_name VARCHAR(100),
    cpu_cores INTEGER,
    ram_mb INTEGER,
    disk_gb INTEGER,
    ip_address VARCHAR(45),
    status VARCHAR(20),
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    expires_at DATETIME,
    FOREIGN KEY (user_id) REFERENCES users(id)
);

CREATE TABLE IF NOT EXISTS system_metrics (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    cpu_usage FLOAT,
    ram_usage FLOAT,
    disk_usage FLOAT,
    network_rx BIGINT,
    network_tx BIGINT,
    active_connections INTEGER,
    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS user_sessions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    session_token VARCHAR(255),
    ip_address VARCHAR(45),
    user_agent TEXT,
    login_time DATETIME DEFAULT CURRENT_TIMESTAMP,
    logout_time DATETIME,
    FOREIGN KEY (user_id) REFERENCES users(id)
);

CREATE TABLE IF NOT EXISTS logs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    action VARCHAR(100),
    description TEXT,
    ip_address VARCHAR(45),
    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id)
);

INSERT OR IGNORE INTO users (username, password, email, role) 
