#!/bin/bash

clear
echo "====================================="
echo "     INSTALADOR PRO SSH PANEL"
echo "====================================="

PANEL_DIR="/var/www/sshpanel"
ZIP_URL="PON_AQUI_TU_LINK_RAW_DEL_ZIP"

# -------------------------
# Instalar dependencias
# -------------------------

echo "Instalando dependencias..."

if command -v apt >/dev/null 2>&1; then
    apt update -y
    apt install apache2 mysql-server php php-mysql unzip wget -y
    systemctl enable apache2
    systemctl start apache2
elif command -v yum >/dev/null 2>&1; then
    yum install httpd mariadb-server php php-mysqlnd unzip wget -y
    systemctl enable httpd
    systemctl start httpd
    systemctl enable mariadb
    systemctl start mariadb
fi

# -------------------------
# Pedir datos admin
# -------------------------

echo ""
read -p "Ingrese usuario ADMIN: " ADMIN_USER
read -s -p "Ingrese contraseña ADMIN: " ADMIN_PASS
echo ""

# -------------------------
# Generar datos MySQL
# -------------------------

DB_NAME="ssh_panel"
DB_USER="paneluser"
DB_PASS=$(openssl rand -base64 12)

echo "Configurando base de datos..."

mysql -u root <<MYSQL_SCRIPT

CREATE DATABASE IF NOT EXISTS $DB_NAME;
CREATE USER IF NOT EXISTS '$DB_USER'@'localhost' IDENTIFIED BY '$DB_PASS';
GRANT ALL PRIVILEGES ON $DB_NAME.* TO '$DB_USER'@'localhost';
FLUSH PRIVILEGES;

MYSQL_SCRIPT

# -------------------------
# Crear tablas internas
# -------------------------

echo "Creando tablas..."

mysql -u root $DB_NAME <<MYSQL_TABLE

CREATE TABLE IF NOT EXISTS admins (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    password TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

MYSQL_TABLE

# -------------------------
# Encriptar contraseña
# -------------------------

HASHED_PASS=$(php -r "echo password_hash('$ADMIN_PASS', PASSWORD_DEFAULT);")

mysql -u root $DB_NAME <<MYSQL_USER

INSERT INTO admins (username, password)
VALUES ('$ADMIN_USER', '$HASHED_PASS');

MYSQL_USER

# -------------------------
# Descargar panel
# -------------------------

echo "Descargando panel..."

mkdir -p $PANEL_DIR
cd /var/www

wget -O panelssh.zip "$ZIP_URL"
unzip -o panelssh.zip -d $PANEL_DIR

# Si detecta carpeta interna, la corrige
if [ -d "$PANEL_DIR/sshpanel" ]; then
    mv $PANEL_DIR/sshpanel/* $PANEL_DIR/
    rm -rf $PANEL_DIR/sshpanel
fi

# -------------------------
# Configurar config.php
# -------------------------

echo "Configurando archivo config.php..."

sed -i "s/paneluser/$DB_USER/" $PANEL_DIR/config.php
sed -i "s/password_aqui/$DB_PASS/" $PANEL_DIR/config.php

# -------------------------
# Permisos
# -------------------------

chown -R www-data:www-data $PANEL_DIR 2>/dev/null
chown -R apache:apache $PANEL_DIR 2>/dev/null
chmod -R 755 $PANEL_DIR

# -------------------------
# Reiniciar servicios
# -------------------------

systemctl restart apache2 2>/dev/null
systemctl restart httpd 2>/dev/null

clear
echo "====================================="
echo " INSTALACIÓN COMPLETADA CON ÉXITO"
echo "====================================="
echo ""
echo "Accede a:"
echo "http://$(curl -s ifconfig.me)/sshpanel"
echo ""
echo "Usuario: $ADMIN_USER"
echo "====================================="
