#!/usr/bin/env bash
set -e

# ========= CONFIGURACIÓN =========
PANEL_URL="https://raw.githubusercontent.com/RmXF/Dev/main/panelssh.zip"
PANEL_DIR="/var/www/sshpanel"
DB_NAME="ssh_panel"
DB_USER="paneluser"
DB_PASS=$(openssl rand -hex 12)
# =================================

echo "====================================="
echo "        INSTALADOR SSH PANEL VI"
echo "====================================="
echo

# Verificar root
if [ "$(id -u)" -ne 0 ]; then
  echo "Ejecuta este script como root."
  exit 1
fi

read -p "Ingrese contraseña para admin: " ADMIN_PASS
echo

if [ -z "$ADMIN_PASS" ]; then
  echo "La contraseña no puede estar vacía."
  exit 1
fi

echo "Instalando dependencias..."
apt update -y
apt install -y nginx php-fpm php-mysql mariadb-server unzip curl

echo "Iniciando MariaDB..."
systemctl enable mariadb
systemctl start mariadb

echo "Configurando base de datos..."

mysql -u root <<MYSQL_SCRIPT
CREATE DATABASE IF NOT EXISTS $DB_NAME;
CREATE USER IF NOT EXISTS '$DB_USER'@'localhost' IDENTIFIED BY '$DB_PASS';
GRANT ALL PRIVILEGES ON $DB_NAME.* TO '$DB_USER'@'localhost';
FLUSH PRIVILEGES;
MYSQL_SCRIPT

echo "Preparando directorio..."
rm -rf "$PANEL_DIR"
mkdir -p "$PANEL_DIR"

echo "Descargando panel..."
curl -L "$PANEL_URL" -o /tmp/panel.zip

# Verificar que realmente sea ZIP
if ! file /tmp/panel.zip | grep -q "Zip archive"; then
  echo "ERROR: El archivo descargado no es un ZIP válido."
  echo "Verifica que el enlace RAW sea correcto."
  exit 1
fi

echo "Extrayendo archivos..."
rm -rf /tmp/panel_extract
mkdir -p /tmp/panel_extract
unzip -q /tmp/panel.zip -d /tmp/panel_extract

# Detectar carpeta interna
INNER_DIR=$(find /tmp/panel_extract -mindepth 1 -maxdepth 1 -type d | head -n 1)

if [ -n "$INNER_DIR" ]; then
    echo "Detectada carpeta interna. Ajustando estructura..."
    mv "$INNER_DIR"/* "$PANEL_DIR"/
else
    mv /tmp/panel_extract/* "$PANEL_DIR"/
fi

rm -rf /tmp/panel_extract
rm -f /tmp/panel.zip

# Verificar install.sql
if [ ! -f "$PANEL_DIR/install.sql" ]; then
  echo "ERROR: install.sql no encontrado en el panel."
  exit 1
fi

echo "Creando tablas..."
mysql -u root "$DB_NAME" < "$PANEL_DIR/install.sql"

echo "Configurando credenciales en config.php..."
sed -i "s/password_aqui/$DB_PASS/g" "$PANEL_DIR/config.php"

echo "Creando usuario admin..."
HASHED_PASS=$(php -r "echo password_hash('$ADMIN_PASS', PASSWORD_DEFAULT);")

mysql -u root "$DB_NAME" <<MYSQL_ADMIN
INSERT INTO admins (username, password)
VALUES ('admin', '$HASHED_PASS');
MYSQL_ADMIN

echo "Configurando permisos..."
chown -R www-data:www-data "$PANEL_DIR"
chmod -R 755 "$PANEL_DIR"

echo "Configurando Nginx..."

PHP_VERSION=$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;')

cat > /etc/nginx/sites-available/sshpanel <<NGINX
server {
    listen 80;
    server_name _;
    root $PANEL_DIR;
    index index.php index.html;

    location / {
        try_files \$uri \$uri/ /index.php;
    }

    location ~ \.php\$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php${PHP_VERSION}-fpm.sock;
    }

    location ~ /\.ht {
        deny all;
    }
}
NGINX

ln -sf /etc/nginx/sites-available/sshpanel /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default

nginx -t
systemctl restart nginx
systemctl restart php${PHP_VERSION}-fpm

IP=$(hostname -I | awk '{print $1}')

echo
echo "====================================="
echo "        INSTALACIÓN COMPLETADA"
echo "====================================="
echo "URL: http://$IP/"
echo "Usuario: admin"
echo "Contraseña: $ADMIN_PASS"
echo "====================================="
echo
echo "Guarda estas credenciales."
