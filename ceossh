import { exec } from 'child_process';
import { promisify } from 'util';
import fs from 'fs/promises';

const execAsync = promisify(exec);

// Archivos de datos
const TOKEN_FILE = '/etc/token/BD';
const CLIENT_FILE = '/etc/token/.clientes';

// Autenticación
function authenticate(req) {
  const authHeader = req.headers.authorization;
  if (!authHeader) return false;
  
  const base64 = authHeader.split(' ')[1];
  const [user, pass] = Buffer.from(base64, 'base64').toString().split(':');
  
  // Leer credenciales guardadas
  // En producción, esto debería ser más seguro
  return (user === 'admin' && pass === 'admin123');
}

export default async function handler(req, res) {
  const { action } = req.query;
  
  // Configurar CORS
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');
  
  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }
  
  // Autenticación (excepto para health)
  if (action !== 'health') {
    const auth = req.headers.authorization;
    if (!auth) {
      return res.status(401).json({ error: 'No autorizado' });
    }
  }
  
  try {
    switch (action) {
      case 'users':
        if (req.method === 'GET') {
          // Obtener usuarios
          const { stdout } = await execAsync("awk -F: '$3 >= 1000 && $1 != \"nobody\" {print $1}' /etc/passwd");
          const users = stdout.trim().split('\n').filter(u => u);
          
          const usersData = await Promise.all(users.map(async (user) => {
            const { stdout: expOut } = await execAsync(`chage -l ${user} | grep "Account expires" | cut -d: -f2`);
            const expiration = expOut.trim();
            const isActive = expiration === 'never' || new Date(expiration) > new Date();
            
            return {
              username: user,
              expiration: expiration === 'never' ? 'Nunca expira' : expiration,
              status: isActive ? 'active' : 'inactive'
            };
          }));
          
          return res.status(200).json(usersData);
        } else if (req.method === 'POST') {
          const { username, days } = req.body;
          if (!username || !days) {
            return res.status(400).json({ error: 'Faltan datos' });
          }
          
          const password = Math.random().toString(36).slice(-8);
          const expDate = new Date();
          expDate.setDate(expDate.getDate() + parseInt(days));
          const expDateStr = expDate.toISOString().split('T')[0];
          
          const { stdout, stderr } = await execAsync(
            `useradd -m -s /bin/false -e ${expDateStr} ${username} 2>&1 && echo "${username}:${password}" | chpasswd 2>&1`
          );
          
          if (stderr && !stderr.includes('warning')) {
            return res.status(500).json({ error: stderr });
          }
          
          // Guardar en archivo de tokens
          await fs.appendFile(TOKEN_FILE, username + '\n').catch(() => {});
          
          return res.status(201).json({ 
            success: true, 
            username, 
            password,
            expiration: expDateStr,
            days
          });
        }
        break;
        
      case 'stats':
        const [totalUsers, onlineUsers, loadAvg] = await Promise.all([
          execAsync("cat /etc/passwd | grep -c '/home'").then(r => parseInt(r.stdout.trim())).catch(() => 0),
          execAsync("ps aux | grep -E 'sshd|dropbear' | grep -v grep | wc -l").then(r => parseInt(r.stdout.trim())).catch(() => 0),
          execAsync("cat /proc/loadavg | awk '{print $1}'").then(r => parseFloat(r.stdout.trim())).catch(() => 0)
        ]);
        
        return res.status(200).json({
          total_users: totalUsers,
          online_users: onlineUsers,
          server_load: loadAvg
        });
        
      case 'delete':
        if (req.method === 'DELETE') {
          const { username } = req.body;
          if (!username) return res.status(400).json({ error: 'Usuario requerido' });
          
          await execAsync(`userdel -r -f ${username} 2>&1`);
          return res.status(200).json({ success: true });
        }
        break;
        
      case 'extend':
        if (req.method === 'PUT') {
          const { username, days } = req.body;
          if (!username || !days) return res.status(400).json({ error: 'Faltan datos' });
          
          const newDate = new Date();
          newDate.setDate(newDate.getDate() + parseInt(days));
          const newDateStr = newDate.toISOString().split('T')[0];
          
          await execAsync(`usermod -e ${newDateStr} ${username} 2>&1`);
          return res.status(200).json({ success: true, new_expiration: newDateStr });
        }
        break;
        
      case 'health':
        return res.status(200).json({ status: 'ok', timestamp: new Date().toISOString() });
        
      default:
        return res.status(404).json({ error: 'Endpoint no encontrado' });
    }
  } catch (error) {
    console.error(error);
    return res.status(500).json({ error: error.message });
  }
  
  return res.status(405).json({ error: 'Método no permitido' });
}
APIROUTE

