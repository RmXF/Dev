    if ($user !== trim($creds[0]) || $pass !== trim($creds[1])) {
        http_response_code(401);
        echo json_encode(['error' => 'Credenciales inválidas']);
        exit;
    }
    return true;
}

// Obtener todos los usuarios
function getUsers() {
    $users = [];
    if (file_exists(TOKEN_FILE)) {
        $tokens = array_filter(file(TOKEN_FILE, FILE_IGNORE_NEW_LINES));
        foreach ($tokens as $token) {
            $user_info = getUserInfo($token);
            if ($user_info) {
                $users[] = $user_info;
            }
        }
    }
    return $users;
}

// Obtener información de un usuario específico
function getUserInfo($username) {
    $user_data = shell_exec("chage -l $username 2>/dev/null");
    if (!$user_data) return null;
    
    preg_match('/Account expires.*: (.+)$/m', $user_data, $exp_match);
    $expires = trim($exp_match[1] ?? 'never');
    
    // Obtener datos del archivo de clientes
    $client_info = '';
    if (file_exists(CLIENT_FILE)) {
        $lines = file(CLIENT_FILE, FILE_IGNORE_NEW_LINES);
        foreach ($lines as $line) {
            if (strpos($line, $username) !== false) {
                $client_info = $line;
                break;
            }
        }
    }
    
    return [
        'username' => $username,
        'expiration' => $expires,
        'status' => isUserActive($username) ? 'active' : 'inactive',
        'client_info' => $client_info
    ];
}

// Verificar si usuario está activo
function isUserActive($username) {
    $exp_date = shell_exec("chage -l $username | grep 'Account expires' | cut -d: -f2");
    $exp_date = trim($exp_date);
    
    if ($exp_date === 'never') return true;
    
    $exp_timestamp = strtotime($exp_date);
    return $exp_timestamp > time();
}

// Crear nuevo usuario
function createUser($username, $days, $password = null) {
    // Verificar si ya existe
    $check = shell_exec("id $username 2>/dev/null");
    if ($check) return ['error' => 'Usuario ya existe'];
    
    $password = $password ?: bin2hex(random_bytes(8));
    $exp_date = date('Y-m-d', strtotime("+$days days"));
    
    // Crear usuario
    $create = shell_exec("useradd -m -s /bin/false -e $exp_date $username 2>&1");
    if ($create) return ['error' => $create];
    
    // Establecer contraseña
    shell_exec("echo '$username:$password' | chpasswd");
    
    // Guardar en archivo de tokens
    file_put_contents(TOKEN_FILE, $username . "\n", FILE_APPEND);
    
    // Guardar en archivo de clientes
    $date = date('d/m/Y');
    $time = date('H:i');
    file_put_contents(CLIENT_FILE, "$username $username $date $time\n", FILE_APPEND);
    
    return [
        'success' => true,
        'username' => $username,
        'password' => $password,
        'expiration' => $exp_date,
        'days' => $days
    ];
}

// Eliminar usuario
function deleteUser($username) {
    $delete = shell_exec("userdel -r -f $username 2>&1");
    
    // Eliminar de archivos
    if (file_exists(TOKEN_FILE)) {
        $tokens = file(TOKEN_FILE, FILE_IGNORE_NEW_LINES);
        $tokens = array_filter($tokens, fn($t) => $t !== $username);
        file_put_contents(TOKEN_FILE, implode("\n", $tokens) . "\n");
    }
    
    if (file_exists(CLIENT_FILE)) {
        $clients = file(CLIENT_FILE, FILE_IGNORE_NEW_LINES);
        $clients = array_filter($clients, fn($c) => strpos($c, $username) !== 0);
        file_put_contents(CLIENT_FILE, implode("\n", $clients) . "\n");
    }
    
    return ['success' => true, 'message' => 'Usuario eliminado'];
}

// Extender expiración
function extendUser($username, $days) {
    $current_exp = shell_exec("chage -l $username | grep 'Account expires' | cut -d: -f2");
    $current_exp = trim($current_exp);
    
    if ($current_exp === 'never') {
        $new_exp = date('Y-m-d', strtotime("+$days days"));
    } else {
        $current_timestamp = strtotime($current_exp);
        $new_timestamp = max($current_timestamp, time()) + ($days * 86400);
        $new_exp = date('Y-m-d', $new_timestamp);
    }
    
    shell_exec("usermod -e $new_exp $username");
    
    return [
        'success' => true,
        'username' => $username,
        'new_expiration' => $new_exp,
        'days_added' => $days
    ];
}

