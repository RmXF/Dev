import { useState, useEffect } from 'react'
import toast from 'react-hot-toast'

export default function Home() {
  const [users, setUsers] = useState([])
  const [stats, setStats] = useState({})
  const [showModal, setShowModal] = useState(false)
  const [newUser, setNewUser] = useState({ username: '', days: 30 })
  const [loading, setLoading] = useState(true)

  const API_URL = typeof window !== 'undefined' ? `${window.location.protocol}//${window.location.hostname}:8080` : 'http://localhost:8080'
  const [auth, setAuth] = useState('')

  useEffect(() => {
    // Prompt for credentials on load
    const user = prompt('Usuario:') || 'admin'
    const pass = prompt('Contraseña:') || 'admin123'
    setAuth(btoa(`${user}:${pass}`))
  }, [])

  const fetchData = async () => {
    if (!auth) return
    try {
      const [usersRes, statsRes] = await Promise.all([
        fetch(`${API_URL}/users`, {
          headers: { 'Authorization': `Basic ${auth}` }
        }),
        fetch(`${API_URL}/stats`, {
          headers: { 'Authorization': `Basic ${auth}` }
        })
      ])
      
      if (usersRes.ok) setUsers(await usersRes.json())
      if (statsRes.ok) setStats(await statsRes.json())
    } catch (error) {
      toast.error('Error al cargar datos')
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    if (auth) {
      fetchData()
      const interval = setInterval(fetchData, 30000)
      return () => clearInterval(interval)
    }
  }, [auth])

  const createUser = async () => {
    if (!newUser.username) {
      toast.error('Ingrese un nombre de usuario')
      return
    }

    try {
      const res = await fetch(`${API_URL}/users`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Basic ${auth}`
        },
        body: JSON.stringify(newUser)
      })

      const data = await res.json()
      if (data.error) {
        toast.error(data.error)
      } else {
        toast.success(`Usuario ${data.username} creado con contraseña: ${data.password}`)
        setShowModal(false)
        setNewUser({ username: '', days: 30 })
        fetchData()
      }
    } catch (error) {
      toast.error('Error al crear usuario')
    }
  }

  const deleteUser = async (username) => {
    if (confirm(`¿Eliminar usuario ${username}?`)) {
      try {
        const res = await fetch(`${API_URL}/users/${username}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Basic ${auth}` }
        })
        
        if (res.ok) {
          toast.success('Usuario eliminado')
          fetchData()
        } else {
          toast.error('Error al eliminar')
        }
      } catch (error) {
        toast.error('Error al eliminar')
      }
    }
  }

  const extendUser = async (username) => {
    const days = prompt('¿Cuántos días agregar?', '30')
    if (days) {
      try {
        const res = await fetch(`${API_URL}/users/${username}`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Basic ${auth}`
          },
          body: JSON.stringify({ days: parseInt(days) })
        })
        
        if (res.ok) {
          toast.success(`Extendido ${days} días`)
          fetchData()
        } else {
          toast.error('Error al extender')
        }
      } catch (error) {
        toast.error('Error al extender')
      }
    }
  }

  if (loading) {
    return (
      <div className="container" style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', height: '100vh' }}>
        <h2>Cargando panel...</h2>
      </div>
    )
  }

  return (
    <div className="container fade-in">
      <div className="header">
        <h1>🚀 Onlycode VPN - Panel de Control</h1>
        <p>Gestión completa de usuarios y tokens VPN</p>
      </div>

      <div className="stats-grid">
        <div className="stat-card">
          <div className="stat-title">Total Usuarios</div>
          <div className="stat-value">{stats.total_users || 0}</div>
        </div>
        <div className="stat-card">
          <div className="stat-title">Usuarios Online</div>
          <div className="stat-value">{stats.online_users || 0}</div>
        </div>
        <div className="stat-card">
          <div className="stat-title">Carga del Servidor</div>
          <div className="stat-value">{stats.server_load || 0}</div>
        </div>
        <div className="stat-card">
          <div className="stat-title">Uso de Disco</div>
          <div className="stat-value">{stats.disk_usage || 0}%</div>
        </div>
      </div>

      <div style={{ marginBottom: '20px' }}>
        <button className="btn btn-primary" onClick={() => setShowModal(true)}>
          + Crear Nuevo Usuario
        </button>
      </div>

      <div className="users-table">
        <table>
          <thead>
            <tr>
              <th>Usuario</th>
              <th>Expiración</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {users.map((user, index) => (
              <tr key={index}>
                <td>{user.username}</td>
                <td>{user.expiration}</td>
                <td className={user.status === 'active' ? 'status-active' : 'status-inactive'}>
                  {user.status === 'active' ? '🟢 Activo' : '🔴 Expirado'}
                </td>
                <td>
                  <button 
                    className="btn btn-warning" 
                    style={{ marginRight: '10px' }}
                    onClick={() => extendUser(user.username)}
                  >
                    Extender
                  </button>
                  <button 
                    className="btn btn-danger"
                    onClick={() => deleteUser(user.username)}
                  >
                    Eliminar
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {showModal && (
        <div className="modal" onClick={() => setShowModal(false)}>
          <div className="modal-content" onClick={(e) => e.stopPropagation()}>
            <h2>Crear Nuevo Usuario</h2>
            <input
              type="text"
              placeholder="Nombre de usuario"
              value={newUser.username}
              onChange={(e) => setNewUser({ ...newUser, username: e.target.value })}
            />
            <select
              value={newUser.days}
              onChange={(e) => setNewUser({ ...newUser, days: parseInt(e.target.value) })}
            >
              <option value="7">7 días</option>
              <option value="15">15 días</option>
              <option value="30">30 días</option>
              <option value="60">60 días</option>
              <option value="90">90 días</option>
              <option value="180">180 días</option>
              <option value="365">365 días</option>
            </select>
            <div style={{ display: 'flex', gap: '10px', marginTop: '20px' }}>
              <button className="btn btn-primary" onClick={createUser}>Crear</button>
              <button className="btn btn-danger" onClick={() => setShowModal(false)}>Cancelar</button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
