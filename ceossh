  const [auth, setAuth] = useState('')

  useEffect(() => {
    const user = prompt('🔐 Usuario admin:') || 'admin'
    const pass = prompt('🔑 Contraseña:') || 'admin123'
    setAuth(btoa(`${user}:${pass}`))
  }, [])

  const fetchData = async () => {
    if (!auth) return
    try {
      const [usersRes, statsRes] = await Promise.all([
        fetch('/api/users', { headers: { 'Authorization': `Basic ${auth}` } }),
        fetch('/api/stats', { headers: { 'Authorization': `Basic ${auth}` } })
      ])
      
      if (usersRes.ok) setUsers(await usersRes.json())
      if (statsRes.ok) setStats(await statsRes.json())
    } catch (error) {
      toast.error('Error al cargar datos')
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    if (auth) {
      fetchData()
      const interval = setInterval(fetchData, 30000)
      return () => clearInterval(interval)
    }
  }, [auth])

  const createUser = async () => {
    if (!newUser.username) {
      toast.error('Ingrese un nombre de usuario')
      return
    }

    try {
      const res = await fetch('/api/users', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Basic ${auth}`
        },
        body: JSON.stringify(newUser)
      })

      const data = await res.json()
      if (data.error) {
        toast.error(data.error)
      } else {
        toast.success(`✅ Usuario creado!\nUsuario: ${data.username}\nContraseña: ${data.password}`)
        setShowModal(false)
        setNewUser({ username: '', days: 30 })
        fetchData()
      }
    } catch (error) {
      toast.error('Error al crear usuario')
    }
  }

  const deleteUser = async (username) => {
    if (confirm(`¿Eliminar usuario ${username}?`)) {
      try {
        const res = await fetch('/api/delete', {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Basic ${auth}`
          },
          body: JSON.stringify({ username })
        })
        
        if (res.ok) {
          toast.success('Usuario eliminado')
          fetchData()
        } else {
          toast.error('Error al eliminar')
        }
      } catch (error) {
        toast.error('Error al eliminar')
      }
    }
  }

  const extendUser = async (username) => {
    const days = prompt('¿Cuántos días agregar?', '30')
    if (days && parseInt(days) > 0) {
      try {
        const res = await fetch('/api/extend', {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Basic ${auth}`
          },
          body: JSON.stringify({ username, days: parseInt(days) })
        })
        
        if (res.ok) {
          toast.success(`Extendido ${days} días`)
          fetchData()
        } else {
          toast.error('Error al extender')
        }
      } catch (error) {
        toast.error('Error al extender')
      }
    }
  }

  if (loading) {
    return (
      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', height: '100vh', background: '#0a0a0a', color: '#fff' }}>
        <div style={{ textAlign: 'center' }}>
          <div style={{ fontSize: '48px', marginBottom: '20px' }}>🚀</div>
          <h2>Cargando panel...</h2>
        </div>
      </div>
    )
  }

  return (
    <div style={{
      minHeight: '100vh',
      background: 'linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%)',
      color: '#fff',
      fontFamily: 'Segoe UI, Tahoma, Geneva, Verdana, sans-serif'
    }}>
      <div style={{ maxWidth: '1400px', margin: '0 auto', padding: '20px' }}>
        {/* Header */}
        <div style={{
          background: 'rgba(0,0,0,0.5)',
          backdropFilter: 'blur(10px)',
          padding: '20px',
          borderRadius: '15px',
          marginBottom: '30px',
          border: '1px solid rgba(255,255,255,0.1)'
        }}>
          <h1 style={{ margin: 0 }}>🚀 Onlycode VPN - Panel de Control</h1>
          <p style={{ color: '#888', marginTop: '10px' }}>Gestión completa de usuarios y tokens VPN</p>
        </div>

        {/* Stats Grid */}
        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fit, minmax(250px, 1fr))',
          gap: '20px',
          marginBottom: '30px'
        }}>
          <div style={{
            background: 'rgba(0,0,0,0.5)',
            backdropFilter: 'blur(10px)',
            padding: '20px',
            borderRadius: '15px',
            border: '1px solid rgba(255,255,255,0.1)',
            transition: 'transform 0.3s'
          }}>
            <div style={{ fontSize: '14px', color: '#888', marginBottom: '10px' }}>Total Usuarios</div>
            <div style={{ fontSize: '32px', fontWeight: 'bold', color: '#00ff88' }}>{stats.total_users || 0}</div>
          </div>
          <div style={{
            background: 'rgba(0,0,0,0.5)',
            backdropFilter: 'blur(10px)',
            padding: '20px',
            borderRadius: '15px',
            border: '1px solid rgba(255,255,255,0.1)'
          }}>
            <div style={{ fontSize: '14px', color: '#888', marginBottom: '10px' }}>Usuarios Online</div>
            <div style={{ fontSize: '32px', fontWeight: 'bold', color: '#00ff88' }}>{stats.online_users || 0}</div>
          </div>
          <div style={{
            background: 'rgba(0,0,0,0.5)',
            backdropFilter: 'blur(10px)',
            padding: '20px',
            borderRadius: '15px',
            border: '1px solid rgba(255,255,255,0.1)'
          }}>
            <div style={{ fontSize: '14px', color: '#888', marginBottom: '10px' }}>Carga del Servidor</div>
            <div style={{ fontSize: '32px', fontWeight: 'bold', color: '#00ff88' }}>{stats.server_load || 0}</div>
          </div>
        </div>

        {/* Botón Crear */}
        <div style={{ marginBottom: '20px' }}>
          <button onClick={() => setShowModal(true)} style={{
            padding: '12px 24px',
            background: '#00ff88',
            color: '#000',
            border: 'none',
            borderRadius: '8px',
            cursor: 'pointer',
            fontWeight: 'bold',
            fontSize: '16px'
          }}>
            + Crear Nuevo Usuario
          </button>
        </div>

        {/* Tabla de usuarios */}
        <div style={{
          background: 'rgba(0,0,0,0.5)',
          backdropFilter: 'blur(10px)',
          borderRadius: '15px',
          overflow: 'auto',
          border: '1px solid rgba(255,255,255,0.1)'
        }}>
          <table style={{ width: '100%', borderCollapse: 'collapse' }}>
            <thead>
              <tr style={{ background: 'rgba(0,0,0,0.3)' }}>
                <th style={{ padding: '15px', textAlign: 'left', color: '#00ff88' }}>Usuario</th>
                <th style={{ padding: '15px', textAlign: 'left', color: '#00ff88' }}>Expiración</th>
                <th style={{ padding: '15px', textAlign: 'left', color: '#00ff88' }}>Estado</th>
                <th style={{ padding: '15px', textAlign: 'left', color: '#00ff88' }}>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {users.map((user, index) => (
                <tr key={index} style={{ borderBottom: '1px solid rgba(255,255,255,0.1)' }}>
                  <td style={{ padding: '15px' }}>{user.username}</td>
                  <td style={{ padding: '15px' }}>{user.expiration}</td>
                  <td style={{ padding: '15px', color: user.status === 'active' ? '#00ff88' : '#ff4444' }}>
                    {user.status === 'active' ? '🟢 Activo' : '🔴 Expirado'}
                  </td>
                  <td style={{ padding: '15px' }}>
                    <button onClick={() => extendUser(user.username)} style={{
                      padding: '8px 16px',
                      marginRight: '10px',
                      background: '#ffaa00',
                      color: '#000',
                      border: 'none',
                      borderRadius: '5px',
                      cursor: 'pointer'
                    }}>Extender</button>
                    <button onClick={() => deleteUser(user.username)} style={{
                      padding: '8px 16px',
                      background: '#ff4444',
                      color: '#fff',
                      border: 'none',
                      borderRadius: '5px',
                      cursor: 'pointer'
                    }}>Eliminar</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Modal Crear Usuario */}
        {showModal && (
          <div onClick={() => setShowModal(false)} style={{
            position: 'fixed',
            top: 0,
            left: 0,
            right: 0,
            bottom: 0,
            background: 'rgba(0,0,0,0.8)',
            backdropFilter: 'blur(5px)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            zIndex: 1000
          }}>
            <div onClick={(e) => e.stopPropagation()} style={{
              background: '#1a1a2e',
              padding: '30px',
              borderRadius: '20px',
              minWidth: '400px',
              border: '1px solid #00ff88'
            }}>
              <h2>Crear Nuevo Usuario</h2>
              <input
                type="text"
                placeholder="Nombre de usuario"
                value={newUser.username}
                onChange={(e) => setNewUser({ ...newUser, username: e.target.value })}
                style={{
                  width: '100%',
                  padding: '12px',
                  margin: '10px 0',
                  background: 'rgba(255,255,255,0.1)',
                  border: '1px solid rgba(255,255,255,0.2)',
                  borderRadius: '8px',
                  color: '#fff'
                }}
              />
              <select
                value={newUser.days}
                onChange={(e) => setNewUser({ ...newUser, days: parseInt(e.target.value) })}
                style={{
                  width: '100%',
                  padding: '12px',
                  margin: '10px 0',
                  background: 'rgba(255,255,255,0.1)',
                  border: '1px solid rgba(255,255,255,0.2)',
                  borderRadius: '8px',
                  color: '#fff'
                }}
              >
                <option value="7">7 días</option>
                <option value="15">15 días</option>
                <option value="30">30 días</option>
                <option value="60">60 días</option>
                <option value="90">90 días</option>
                <option value="180">180 días</option>
                <option value="365">365 días</option>
              </select>
              <div style={{ display: 'flex', gap: '10px', marginTop: '20px' }}>
                <button onClick={createUser} style={{
                  padding: '10px 20px',
                  background: '#00ff88',
                  color: '#000',
                  border: 'none',
                  borderRadius: '8px',
                  cursor: 'pointer'
                }}>Crear</button>
                <button onClick={() => setShowModal(false)} style={{
                  padding: '10px 20px',
                  background: '#ff4444',
                  color: '#fff',
                  border: 'none',
                  borderRadius: '8px',
                  cursor: 'pointer'
                }}>Cancelar</button>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  )
}
