# Instalar Nginx
install_nginx() {
    info "Instalando Nginx..."
    
    apt-get install -y nginx
    
    # Crear configuración para CEO SSH
    cat > /etc/nginx/sites-available/ceo-ssh << 'EOF'
server {
    listen 80;
    listen [::]:80;
    server_name _;
    
    root /var/www/ceo-ssh/frontend/out;
    index index.html index.htm;
    
    # Logs
    access_log /var/log/nginx/ceo-ssh-access.log;
    error_log /var/log/nginx/ceo-ssh-error.log;
    
    # Frontend
    location / {
        try_files $uri $uri/ /index.html;
        add_header X-Frame-Options "SAMEORIGIN";
        add_header X-Content-Type-Options "nosniff";
    }
    
    # API Backend
    location /api {
        proxy_pass http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    
    # WebSocket support
    location /socket.io {
        proxy_pass http://localhost:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }
    
    # PHP Backend (legacy support)
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php8.2-fpm.sock;
        fastcgi_param SCRIPT_FILENAME /var/www/ceo-ssh/backend$fastcgi_script_name;
        include fastcgi_params;
    }
    
    # Deny access to hidden files
    location ~ /\. {
        deny all;
    }
}
EOF
    
    # Habilitar sitio
    ln -sf /etc/nginx/sites-available/ceo-ssh /etc/nginx/sites-enabled/
    rm -f /etc/nginx/sites-enabled/default
    
    # Test config
    nginx -t
    
    systemctl enable nginx
    systemctl restart nginx
    
    success "Nginx configurado en puerto 80"
}

# Descargar y descomprimir panel
download_and_extract_panel() {
    info "Descargando panel CEO SSH..."
    
    # Crear directorio de instalación
    mkdir -p $INSTALL_DIR
    
    # Descargar panel.zip (cambiar URL según tu servidor)
    if [ -f "$PANEL_ZIP_LOCAL" ]; then
        info "Usando panel.zip local..."
        cp $PANEL_ZIP_LOCAL /tmp/ceo-ssh-panel.zip
    else
        info "Descargando desde URL..."
        wget -O /tmp/ceo-ssh-panel.zip $PANEL_ZIP_URL || error "No se pudo descargar el panel"
    fi
    
    # Descomprimir
    info "Descomprimiendo archivos..."
    unzip -o /tmp/ceo-ssh-panel.zip -d $INSTALL_DIR
    
    # Limpiar
    rm -f /tmp/ceo-ssh-panel.zip
    
    success "Panel descomprimido en $INSTALL_DIR"
}

