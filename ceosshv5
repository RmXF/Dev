# Importar base de datos
import_database() {
    info "Importando estructura de base de datos..."
    
    if [ -f "$INSTALL_DIR/database/schema.sql" ]; then
        mysql -u ceo_ssh -p$MYSQL_CEO_PASS ceo_ssh < $INSTALL_DIR/database/schema.sql
        success "Base de datos importada"
    else
        warning "No se encontró schema.sql, creando estructura básica..."
        
        # Crear tablas básicas
        mysql -u ceo_ssh -p$MYSQL_CEO_PASS ceo_ssh << 'SQLEOF'
-- Tabla de usuarios
CREATE TABLE IF NOT EXISTS `users` (
    `id` INT AUTO_INCREMENT PRIMARY KEY,
    `username` VARCHAR(50) UNIQUE NOT NULL,
    `password` VARCHAR(255) NOT NULL,
    `email` VARCHAR(100),
    `role` ENUM('admin', 'user') DEFAULT 'user',
    `status` ENUM('active', 'inactive', 'suspended') DEFAULT 'active',
    `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    `updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    `last_login` TIMESTAMP NULL,
    INDEX idx_username (username),
    INDEX idx_status (status)
);

-- Tabla de sesiones
CREATE TABLE IF NOT EXISTS `sessions` (
    `id` VARCHAR(128) PRIMARY KEY,
    `user_id` INT NOT NULL,
    `ip_address` VARCHAR(45),
    `user_agent` TEXT,
    `payload` TEXT,
    `last_activity` INT,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    INDEX idx_last_activity (last_activity)
);

-- Tabla de tokens SSH
CREATE TABLE IF NOT EXISTS `ssh_tokens` (
    `id` INT AUTO_INCREMENT PRIMARY KEY,
    `username` VARCHAR(50) UNIQUE NOT NULL,
    `password` VARCHAR(255) NOT NULL,
    `expires_at` DATE NOT NULL,
    `status` ENUM('active', 'expired', 'suspended') DEFAULT 'active',
    `traffic_limit` BIGINT DEFAULT NULL,
    `traffic_used` BIGINT DEFAULT 0,
    `created_by` INT,
    `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    `updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    FOREIGN KEY (created_by) REFERENCES users(id),
    INDEX idx_username (username),
    INDEX idx_status (status),
    INDEX idx_expires (expires_at)
);

-- Tabla de logs
CREATE TABLE IF NOT EXISTS `logs` (
    `id` INT AUTO_INCREMENT PRIMARY KEY,
    `user_id` INT,
    `action` VARCHAR(100),
    `details` TEXT,
    `ip_address` VARCHAR(45),
    `created_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id),
    INDEX idx_user (user_id),
    INDEX idx_created (created_at),
    INDEX idx_action (action)
);

-- Tabla de configuración
CREATE TABLE IF NOT EXISTS `settings` (
    `key` VARCHAR(100) PRIMARY KEY,
    `value` TEXT,
    `description` TEXT,
    `updated_at` TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

-- Insertar usuario admin
INSERT INTO `users` (username, password, email, role, status) 
VALUES ('$ADMIN_USER', '$ADMIN_PASS', '$ADMIN_EMAIL', 'admin', 'active')
ON DUPLICATE KEY UPDATE password = '$ADMIN_PASS';

-- Configuraciones por defecto
INSERT INTO `settings` (`key`, `value`, `description`) VALUES
('panel_name', '$PANEL_NAME', 'Nombre del panel'),
('panel_version', '$PANEL_VERSION', 'Versión del panel'),
('maintenance_mode', '0', 'Modo mantenimiento'),
('dark_mode_default', 'dark', 'Tema por defecto'),
('session_timeout', '3600', 'Tiempo de sesión en segundos'),
('max_login_attempts', '5', 'Intentos máximos de login')
ON DUPLICATE KEY UPDATE `value` = VALUES(`value`);
SQLEOF
        
        success "Estructura de base de datos creada"
    fi
}

# Instalar dependencias de Node.js y construir frontend
build_frontend() {
    info "Instalando dependencias del frontend..."
    
    cd $INSTALL_DIR/frontend
    
    # Instalar dependencias
    npm install --production=false
    
    info "Construyendo aplicación Next.js..."
    npm run build
    
    # Exportar como sitio estático
    npm run export || true
    
    success "Frontend construido"
}

# Configurar servicios systemd
configure_services() {
    info "Configurando servicios systemd..."
    
    # Servicio API (Node.js/Express)
    cat > /etc/systemd/system/ceo-ssh-api.service << EOF
[Unit]
Description=CEO SSH Panel API Service
After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=$INSTALL_DIR/backend
ExecStart=/usr/bin/node $INSTALL_DIR/backend/server.js
Restart=always
RestartSec=10
Environment="NODE_ENV=production"
Environment="PORT=$API_PORT"

[Install]
WantedBy=multi-user.target
EOF
    
    # Servicio WebSocket
    cat > /etc/systemd/system/ceo-ssh-ws.service << EOF
[Unit]
Description=CEO SSH Panel WebSocket Service
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=$INSTALL_DIR/backend
ExecStart=/usr/bin/node $INSTALL_DIR/backend/websocket.js
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
    
    # Recargar systemd
    systemctl daemon-reload
    
    # Habilitar servicios
    systemctl enable ceo-ssh-api.service
    systemctl enable ceo-ssh-ws.service
    
    # Iniciar servicios
    systemctl start ceo-ssh-api.service
    systemctl start ceo-ssh-ws.service
    
    success "Servicios configurados e iniciados"
}

# Configurar firewall
configure_firewall() {
    info "Configurando firewall..."
    
    # Configurar UFW
    ufw --force disable
    ufw default deny incoming
    ufw default allow outgoing
    ufw allow 22/tcp comment 'SSH'
    ufw allow 80/tcp comment 'HTTP Panel'
    ufw allow 443/tcp comment 'HTTPS Panel'
    ufw allow $API_PORT/tcp comment 'CEO SSH API'
    
    # Puertos SSH/VPN
    ufw allow 22/tcp comment 'SSH'
    ufw allow 443/udp comment 'OpenVPN'
    ufw allow 1194/udp comment 'OpenVPN'
    ufw allow 7300/tcp comment 'Dropbear'
    ufw allow 8000/tcp comment 'Stunnel'
    ufw allow 3128/tcp comment 'Squid'
    
    ufw --force enable
    
    # Configurar fail2ban
    systemctl enable fail2ban
    systemctl start fail2ban
    
    success "Firewall configurado"
}

