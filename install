#!/bin/bash

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}======================================${NC}"
echo -e "${GREEN}   Sistema de Notificaciones Telegram${NC}"
echo -e "${BLUE}======================================${NC}"

# Verificar que se ejecute como root
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}Este script debe ejecutarse como root${NC}" 
   exit 1
fi

# Detener y deshabilitar Apache si está instalado
echo -e "${YELLOW}Verificando servicios web...${NC}"
if systemctl is-active --quiet apache2; then
    echo -e "${YELLOW}Deteniendo Apache2...${NC}"
    systemctl stop apache2
    systemctl disable apache2
fi

# Actualizar sistema
echo -e "${YELLOW}Actualizando sistema...${NC}"
apt-get update -y && apt-get upgrade -y

# Instalar dependencias
echo -e "${YELLOW}Instalando dependencias...${NC}"
apt-get install -y python3 python3-pip python3-venv nginx sqlite3 curl jq git

# Crear directorio de la aplicación
mkdir -p /opt/notify-bot
cd /opt/notify-bot

# Crear entorno virtual
python3 -m venv venv
source venv/bin/activate

# Instalar paquetes Python
pip install --upgrade pip
pip install flask flask-sqlalchemy flask-cors requests python-telegram-bot schedule

# Crear estructura de directorios
mkdir -p templates static/css static/js static/img

# Configurar permisos
chown -R www-data:www-data /opt/notify-bot
chmod -R 755 /opt/notify-bot

# Crear archivo de configuración
cat > /opt/notify-bot/config.json << EOF
{
    "bot_token": "",
    "chat_id": ""
}
EOF

# Crear el panel web y la API
cat > /opt/notify-bot/app.py << 'EOF'
from flask import Flask, render_template, request, jsonify, session
from flask_sqlalchemy import SQLAlchemy
from flask_cors import CORS
from datetime import datetime, timedelta
import requests
import json
import os
import threading
import time
import schedule
import subprocess
import logging

# Configurar logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

app = Flask(__name__)
app.secret_key = os.urandom(24)
CORS(app)

# Configuración de la base de datos
app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///notas.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False
db = SQLAlchemy(app)

# Modelo de Notas
class Nota(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    titulo = db.Column(db.String(200), nullable=False)
    contenido = db.Column(db.Text, nullable=False)
    fecha_hora = db.Column(db.DateTime, nullable=False)
    enviado = db.Column(db.Boolean, default=False)
    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    telegram_respuesta = db.Column(db.Text, nullable=True)

    def to_dict(self):
        return {
            'id': self.id,
            'titulo': self.titulo,
            'contenido': self.contenido,
            'fecha_hora': self.fecha_hora.strftime('%Y-%m-%d %H:%M:%S'),
            'enviado': self.enviado,
            'created_at': self.created_at.strftime('%Y-%m-%d %H:%M:%S')
        }

# Crear tablas
with app.app_context():
    db.create_all()
    logger.info("Base de datos creada/verificada")

# Cargar configuración
def load_config():
    try:
        with open('/opt/notify-bot/config.json', 'r') as f:
            return json.load(f)
    except:
        return {"bot_token": "", "chat_id": ""}

def save_config(token, chat_id):
    config = {"bot_token": token, "chat_id": chat_id}
    with open('/opt/notify-bot/config.json', 'w') as f:
        json.dump(config, f)
    logger.info("Configuración guardada")

# Función para enviar mensaje a Telegram
def send_telegram_message(nota):
    config = load_config()
    if not config['bot_token'] or not config['chat_id']:
        return "Bot no configurado"
    
    message = f"""
📝 *NUEVA NOTA PENDIENTE*
━━━━━━━━━━━━━━━━━━━
*Título:* {nota.titulo}
*Mensaje:* {nota.contenido}
*Fecha/Hora:* {nota.fecha_hora.strftime('%d/%m/%Y %H:%M:%S')}
━━━━━━━━━━━━━━━━━━━
✅ *Recordatorio programado*
    """
    
    url = f"https://api.telegram.org/bot{config['bot_token']}/sendMessage"
    payload = {
        'chat_id': config['chat_id'],
        'text': message,
        'parse_mode': 'Markdown'
    }
    
    try:
        response = requests.post(url, data=payload, timeout=10)
        if response.status_code == 200:
            nota.enviado = True
            db.session.commit()
            logger.info(f"Mensaje enviado para nota ID: {nota.id}")
            return "✅ Mensaje enviado"
        else:
            logger.error(f"Error Telegram: {response.text}")
            return f"❌ Error: {response.text}"
    except Exception as e:
        logger.error(f"Excepción: {str(e)}")
        return f"❌ Error: {str(e)}"

# Función para verificar notas pendientes
def check_pending_notes():
    with app.app_context():
        ahora = datetime.now()
        notas_pendientes = Nota.query.filter(
            Nota.fecha_hora <= ahora,
            Nota.enviado == False
        ).all()
        
        for nota in notas_pendientes:
            logger.info(f"Procesando nota pendiente ID: {nota.id}")
            resultado = send_telegram_message(nota)
            nota.telegram_respuesta = resultado
            db.session.commit()

# Programar verificación cada minuto
def run_scheduler():
    schedule.every(1).minutes.do(check_pending_notes)
    while True:
        schedule.run_pending()
        time.sleep(1)

# Iniciar scheduler en hilo separado
scheduler_thread = threading.Thread(target=run_scheduler, daemon=True)
scheduler_thread.start()
logger.info("Scheduler iniciado")

# API Endpoints
@app.route('/api/estado-vps')
def estado_vps():
    try:
        # Obtener estadísticas del VPS
        cpu = subprocess.check_output("top -bn1 | grep 'Cpu(s)' | awk '{print $2}' | cut -d'%' -f1", shell=True).decode().strip()
        mem = subprocess.check_output("free -m | awk 'NR==2{printf \"%.2f\", $3*100/$2 }'", shell=True).decode().strip()
        disk = subprocess.check_output("df -h / | awk 'NR==2{print $5}'", shell=True).decode().strip()
        uptime = subprocess.check_output("uptime -p", shell=True).decode().strip()
        
        return jsonify({
            'cpu': float(cpu) if cpu else 0,
            'memoria': float(mem) if mem else 0,
            'disco': disk.strip(),
            'uptime': uptime.strip(),
            'status': 'ok'
        })
    except Exception as e:
        logger.error(f"Error en estado VPS: {str(e)}")
        return jsonify({'status': 'error', 'message': str(e)})

@app.route('/api/notas', methods=['GET'])
def get_notas():
    notas = Nota.query.order_by(Nota.fecha_hora.desc()).all()
    return jsonify([n.to_dict() for n in notas])

@app.route('/api/notas', methods=['POST'])
def create_nota():
    try:
        data = request.json
        nota = Nota(
            titulo=data['titulo'],
            contenido=data['contenido'],
            fecha_hora=datetime.strptime(data['fecha_hora'], '%Y-%m-%dT%H:%M')
        )
        db.session.add(nota)
        db.session.commit()
        logger.info(f"Nota creada ID: {nota.id}")
        return jsonify(nota.to_dict()), 201
    except Exception as e:
        logger.error(f"Error creando nota: {str(e)}")
        return jsonify({'error': str(e)}), 400

@app.route('/api/notas/<int:id>', methods=['DELETE'])
def delete_nota(id):
    nota = Nota.query.get_or_404(id)
    db.session.delete(nota)
    db.session.commit()
    logger.info(f"Nota eliminada ID: {id}")
    return jsonify({'status': 'deleted'})

@app.route('/api/configurar-bot', methods=['POST'])
def configurar_bot():
    data = request.json
    save_config(data['token'], data['chat_id'])
    
    # Probar conexión
    url = f"https://api.telegram.org/bot{data['token']}/getMe"
    try:
        response = requests.get(url, timeout=10)
        if response.status_code == 200:
            return jsonify({'status': 'success', 'message': 'Bot configurado correctamente'})
        else:
            return jsonify({'status': 'error', 'message': 'Token inválido'})
    except Exception as e:
        return jsonify({'status': 'error', 'message': f'Error de conexión: {str(e)}'})

@app.route('/api/estadisticas')
def estadisticas():
    total = Nota.query.count()
    enviadas = Nota.query.filter_by(enviado=True).count()
    pendientes = Nota.query.filter_by(enviado=False).count()
    return jsonify({
        'total': total,
        'enviadas': enviadas,
        'pendientes': pendientes
    })

@app.route('/')
def index():
    return render_template('index.html')

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=False)
EOF

