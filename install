        <!-- Nueva Nota Section -->
        <div id="nueva-nota" class="content-section" style="display: none;">
            <div class="dashboard-card">
                <h2><i class="fas fa-plus-circle"></i> Crear Nueva Nota</h2>
                <p style="color: #666; margin-top: 5px;">Programa un recordatorio que se enviará a Telegram en la fecha y hora especificada</p>
                <form id="nota-form" style="margin-top: 30px;">
                    <div class="form-group">
                        <label>Título de la nota</label>
                        <input type="text" id="titulo" class="form-control" placeholder="Ej: Reunión importante" required>
                    </div>
                    <div class="form-group">
                        <label>Contenido / Mensaje</label>
                        <textarea id="contenido" class="form-control" rows="5" placeholder="Escribe aquí el mensaje que se enviará a Telegram..." required></textarea>
                    </div>
                    <div class="form-group">
                        <label>Fecha y hora de envío</label>
                        <input type="datetime-local" id="fecha_hora" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Guardar Nota
                    </button>
                </form>
            </div>
        </div>

        <!-- Historial Section -->
        <div id="historial" class="content-section" style="display: none;">
            <div class="dashboard-card">
                <h2><i class="fas fa-history"></i> Historial de Notas Enviadas</h2>
                <div id="historial-content" style="margin-top: 20px;"></div>
            </div>
        </div>

        <!-- Listado Notas Section -->
        <div id="listado-notas" class="content-section" style="display: none;">
            <div class="dashboard-card">
                <h2><i class="fas fa-list"></i> Listado Completo de Notas</h2>
                <div id="listado-content" style="margin-top: 20px;"></div>
            </div>
        </div>

        <!-- Configuración Section -->
        <div id="configuracion" class="content-section" style="display: none;">
            <div class="dashboard-card">
                <h2><i class="fas fa-robot"></i> Configuración del Bot de Telegram</h2>
                <p style="color: #666; margin-top: 5px;">Configura tu bot de Telegram para recibir las notificaciones</p>
                <form id="bot-form" style="margin-top: 30px;">
                    <div class="form-group">
                        <label>Token del Bot</label>
                        <input type="text" id="bot-token" class="form-control" placeholder="Ej: 1234567890:ABCdefGHIjklmNOPqrstUvWXyz" required>
                        <small style="color: #666;">Obtén el token de <a href="https://t.me/BotFather" target="_blank">@BotFather</a> en Telegram</small>
                    </div>
                    <div class="form-group">
                        <label>Chat ID</label>
                        <input type="text" id="chat-id" class="form-control" placeholder="Tu Chat ID de Telegram" required>
                        <small style="color: #666;">Obtén tu ID con <a href="https://t.me/userinfobot" target="_blank">@userinfobot</a></small>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check-circle"></i> Guardar y Probar Conexión
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Función para toggle del menú
        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('active');
        }

        // Mostrar notificación toast
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}" style="margin-right: 10px; color: ${type === 'success' ? '#4caf50' : '#f44336'}"></i>${message}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // Mostrar sección seleccionada
        function showSection(section) {
            const sections = ['dashboard', 'nueva-nota', 'historial', 'listado-notas', 'configuracion'];
            sections.forEach(s => {
                const el = document.getElementById(s);
                if (el) el.style.display = 'none';
            });
            const selectedSection = document.getElementById(section);
            if (selectedSection) selectedSection.style.display = 'block';
            document.getElementById('sidebar').classList.remove('active');
            
            if (section === 'dashboard') {
                loadDashboard();
            } else if (section === 'historial') {
                loadHistorial();
            } else if (section === 'listado-notas') {
                loadListado();
            }
        }

        // Cargar Dashboard
        async function loadDashboard() {
            try {
                // Cargar estado VPS
                const estadoResp = await fetch('/api/estado-vps');
                const estado = await estadoResp.json();
                if (estado.status === 'ok') {
                    document.getElementById('cpu-stat').textContent = Math.round(estado.cpu) + '%';
                    document.getElementById('mem-stat').textContent = Math.round(estado.memoria) + '%';
                    document.getElementById('disk-stat').textContent = estado.disco;
                    document.getElementById('uptime-stat').textContent = estado.uptime;
                    
                    // Actualizar barras de progreso
                    document.getElementById('cpu-bar').style.width = estado.cpu + '%';
                    document.getElementById('mem-bar').style.width = estado.memoria + '%';
                }
                
                // Cargar estadísticas de notas
                const statsResp = await fetch('/api/estadisticas');
                const stats = await statsResp.json();
                document.getElementById('total-notas').textContent = stats.total;
                document.getElementById('enviadas-notas').textContent = stats.enviadas;
                document.getElementById('pendientes-notas').textContent = stats.pendientes;
            } catch (error) {
                console.error('Error cargando dashboard:', error);
            }
        }

        // Cargar Historial
        async function loadHistorial() {
            try {
                const resp = await fetch('/api/notas');
                const notas = await resp.json();
                const historial = notas.filter(n => n.enviado === true);
                
                if (historial.length === 0) {
                    document.getElementById('historial-content').innerHTML = '<div style="text-align: center; padding: 40px;"><i class="fas fa-inbox" style="font-size: 48px; color: #ccc;"></i><p style="margin-top: 20px;">No hay notas en el historial</p></div>';
                    return;
                }
                
                let html = '<div style="overflow-x: auto;"><table class="notas-table"><thead><tr><th>Título</th><th>Contenido</th><th>Fecha/Hora</th><th>Estado</th></tr></thead><tbody>';
                historial.forEach(nota => {
                    html += `<tr>
                        <td><strong>${escapeHtml(nota.titulo)}</strong></td>
                        <td>${escapeHtml(nota.contenido.substring(0, 50))}${nota.contenido.length > 50 ? '...' : ''}</td>
                        <td>${nota.fecha_hora}</td>
                        <td><span class="badge badge-success"><i class="fas fa-check"></i> Enviado</span></td>
                    </tr>`;
                });
                html += '</tbody></table></div>';
                document.getElementById('historial-content').innerHTML = html;
            } catch (error) {
                console.error('Error cargando historial:', error);
            }
        }

        // Cargar Listado
        async function loadListado() {
            try {
                const resp = await fetch('/api/notas');
                const notas = await resp.json();
                
                if (notas.length === 0) {
                    document.getElementById('listado-content').innerHTML = '<div style="text-align: center; padding: 40px;"><i class="fas fa-clipboard-list" style="font-size: 48px; color: #ccc;"></i><p style="margin-top: 20px;">No hay notas creadas</p><button class="btn btn-primary" onclick="showSection(\'nueva-nota\')" style="margin-top: 20px;">Crear primera nota</button></div>';
                    return;
                }
                
                let html = '<div style="overflow-x: auto;"><table class="notas-table"><thead><tr><th>Título</th><th>Contenido</th><th>Fecha/Hora</th><th>Estado</th><th>Acciones</th></tr></thead><tbody>';
                notas.forEach(nota => {
                    html += `<tr>
                        <td><strong>${escapeHtml(nota.titulo)}</strong></td>
                        <td>${escapeHtml(nota.contenido.substring(0, 50))}${nota.contenido.length > 50 ? '...' : ''}</td>
                        <td>${nota.fecha_hora}</td>
                        <td>${nota.enviado ? '<span class="badge badge-success"><i class="fas fa-check"></i> Enviado</span>' : '<span class="badge badge-warning"><i class="fas fa-clock"></i> Pendiente</span>'}</td>
                        <td><button onclick="eliminarNota(${nota.id})" class="btn btn-danger" style="padding: 5px 15px; font-size: 12px;"><i class="fas fa-trash"></i> Eliminar</button></td>
                    </tr>`;
                });
                html += '</tbody></table></div>';
                document.getElementById('listado-content').innerHTML = html;
            } catch (error) {
                console.error('Error cargando listado:', error);
            }
        }

        // Eliminar nota
        async function eliminarNota(id) {
            if (confirm('¿Estás seguro de eliminar esta nota?')) {
                try {
                    const resp = await fetch(`/api/notas/${id}`, { method: 'DELETE' });
                    if (resp.ok) {
                        showToast('Nota eliminada correctamente');
                        loadListado();
                        loadDashboard();
                    }
                } catch (error) {
                    showToast('Error al eliminar la nota', 'error');
                }
            }
        }

        // Crear nota
        document.getElementById('nota-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const fechaHora = document.getElementById('fecha_hora').value;
            if (!fechaHora) {
                showToast('Por favor selecciona una fecha y hora', 'error');
                return;
            }
            
            const nota = {
                titulo: document.getElementById('titulo').value,
                contenido: document.getElementById('contenido').value,
                fecha_hora: fechaHora
            };
            
            try {
                const resp = await fetch('/api/notas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(nota)
                });
                
                if (resp.ok) {
                    showToast('Nota creada exitosamente');
                    e.target.reset();
                    loadDashboard();
                    showSection('listado-notas');
                } else {
                    showToast('Error al crear la nota', 'error');
                }
            } catch (error) {
                showToast('Error de conexión', 'error');
            }
        });

        // Configurar bot
        document.getElementById('bot-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const config = {
                token: document.getElementById('bot-token').value,
                chat_id: document.getElementById('chat-id').value
            };
            
            const button = e.target.querySelector('button');
            const originalText = button.innerHTML;
            button.innerHTML = '<span class="loading"></span> Probando...';
            button.disabled = true;
            
            try {
                const resp = await fetch('/api/configurar-bot', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(config)
                });
                
                const result = await resp.json();
                showToast(result.message, result.status === 'success' ? 'success' : 'error');
            } catch (error) {
                showToast('Error de conexión', 'error');
            } finally {
                button.innerHTML = originalText;
                button.disabled = false;
            }
        });

        // Función para escapar HTML
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Cerrar sidebar al hacer click fuera
        document.addEventListener('click', (e) => {
            const sidebar = document.getElementById('sidebar');
            const toggle = document.querySelector('.menu-toggle');
            if (sidebar.classList.contains('active') && !sidebar.contains(e.target) && !toggle.contains(e.target)) {
                sidebar.classList.remove('active');
            }
        });

        // Auto-refresh dashboard cada 30 segundos
        setInterval(() => {
            const dashboard = document.getElementById('dashboard');
            if (dashboard && dashboard.style.display !== 'none') {
                loadDashboard();
            }
        }, 30000);
        
        // Cargar dashboard inicial
        loadDashboard();
    </script>
</body>
</html>
EOF

# Configurar Nginx correctamente
cat > /etc/nginx/sites-available/notify-bot << 'EOF'
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    
    root /var/www/html;
    index index.html index.htm;
    
    server_name _;
    
    location / {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
EOF

# Habilitar el sitio y deshabilitar el default
ln -sf /etc/nginx/sites-available/notify-bot /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default

# Verificar configuración de Nginx
nginx -t

# Crear script de servicio systemd mejorado
cat > /etc/systemd/system/notify-bot.service << 'EOF'
[Unit]
Description=Notify Bot Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/notify-bot
Environment="PATH=/opt/notify-bot/venv/bin"
ExecStart=/opt/notify-bot/venv/bin/python3 /opt/notify-bot/app.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF

# Crear script de configuración del bot
cat > /opt/notify-bot/bot_config.sh << 'EOF'
#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}======================================${NC}"
echo -e "${GREEN}   Configuración del Bot Telegram${NC}"
echo -e "${BLUE}======================================${NC}"

read -p "Ingresa el Token de tu Bot de Telegram: " BOT_TOKEN
read -p "Ingresa tu Chat ID de Telegram: " CHAT_ID

# Guardar configuración
cat > /opt/notify-bot/config.json << EOF
{
    "bot_token": "$BOT_TOKEN",
    "chat_id": "$CHAT_ID"
}
EOF

echo -e "${GREEN}✓ Configuración guardada exitosamente${NC}"

# Probar conexión
echo -e "${BLUE}Probando conexión con Telegram...${NC}"
RESPONSE=$(curl -s "https://api.telegram.org/bot$BOT_TOKEN/getMe")

if echo "$RESPONSE" | grep -q "\"ok\":true"; then
    echo -e "${GREEN}✓ Bot conectado correctamente${NC}"
    BOT_NAME=$(echo "$RESPONSE" | grep -o '"first_name":"[^"]*"' | cut -d'"' -f4)
    echo -e "${GREEN}✓ Bot: $BOT_NAME${NC}"
else
    echo -e "${RED}✗ Error al conectar con el bot. Verifica el token${NC}"
fi

# Reiniciar servicio
systemctl restart notify-bot
echo -e "${GREEN}✓ Servicio reiniciado${NC}"
EOF

chmod +x /opt/notify-bot/bot_config.sh

# Crear script de menú
cat > /opt/notify-bot/menu.sh << 'EOF'
#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

while true; do
    clear
    echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     NOTIFYBOT - MENÚ PRINCIPAL       ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}1.${NC} Configurar Bot de Telegram"
    echo -e "${GREEN}2.${NC} Ver estado del servicio"
    echo -e "${GREEN}3.${NC} Reiniciar servicio"
    echo -e "${GREEN}4.${NC} Ver logs (últimas 50 líneas)"
    echo -e "${GREEN}5.${NC} Ver logs en tiempo real"
    echo -e "${GREEN}6.${NC} Abrir panel web"
    echo -e "${GREEN}7.${NC} Ver información del sistema"
    echo -e "${GREEN}8.${NC} Probar envío de mensaje"
    echo -e "${RED}9.${NC} Salir"
    echo ""
    read -p "Selecciona una opción: " opcion

    case $opcion in
        1)
            /opt/notify-bot/bot_config.sh
            read -p "Presiona Enter para continuar..."
            ;;
        2)
            systemctl status notify-bot --no-pager
            read -p "Presiona Enter para continuar..."
            ;;
        3)
            systemctl restart notify-bot
            echo -e "${GREEN}✓ Servicio reiniciado${NC}"
            sleep 2
            ;;
        4)
            journalctl -u notify-bot -n 50 --no-pager
            read -p "Presiona Enter para continuar..."
            ;;
        5)
            echo -e "${YELLOW}Mostrando logs en tiempo real. Presiona Ctrl+C para salir${NC}"
            sleep 2
            journalctl -u notify-bot -f
            ;;
        6)
            IP=$(curl -s ifconfig.me)
            echo -e "${GREEN}Panel web disponible en: http://$IP${NC}"
            echo -e "${YELLOW}Si no accedes, verifica que el servicio esté corriendo${NC}"
            read -p "Presiona Enter para continuar..."
            ;;
        7)
            echo -e "${BLUE}══════════════════════════════════════${NC}"
            echo -e "${GREEN}Información del sistema:${NC}"
            echo -e "${BLUE}──────────────────────────────────────${NC}"
            echo -e "CPU: $(top -bn1 | grep 'Cpu(s)' | awk '{print $2}')%"
            echo -e "RAM: $(free -h | awk 'NR==2{print $3"/"$2}')"
            echo -e "Disco: $(df -h / | awk 'NR==2{print $5}')"
            echo -e "Uptime: $(uptime -p)"
            echo -e "IP: $(curl -s ifconfig.me)"
            echo -e "${BLUE}══════════════════════════════════════${NC}"
            read -p "Presiona Enter para continuar..."
            ;;
        8)
            echo -e "${YELLOW}Creando nota de prueba...${NC}"
            curl -X POST http://localhost:5000/api/notas \
                -H "Content-Type: application/json" \
                -d '{"titulo":"Prueba","contenido":"Mensaje de prueba","fecha_hora":"'$(date -d "+1 minute" +"%Y-%m-%dT%H:%M")'"}'
            echo -e "\n${GREEN}Nota de prueba creada. Se enviará en 1 minuto${NC}"
            read -p "Presiona Enter para continuar..."
            ;;
        9)
            echo -e "${GREEN}¡Hasta luego!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Opción inválida${NC}"
            sleep 2
            ;;
    esac
done
EOF

chmod +x /opt/notify-bot/menu.sh

# Iniciar servicios
systemctl daemon-reload
systemctl enable notify-bot
systemctl start notify-bot
systemctl restart nginx

# Verificar que todo funciona
sleep 3

# Limpiar
clear

echo -e "${GREEN}======================================${NC}"
echo -e "${GREEN}¡Instalación completada exitosamente!${NC}"
echo -e "${GREEN}======================================${NC}"
echo ""
echo -e "${YELLOW}Para configurar el bot, ejecuta:${NC}"
echo -e "${BLUE}sudo /opt/notify-bot/menu.sh${NC}"
echo ""
echo -e "${YELLOW}Para acceder al panel web:${NC}"
IP=$(curl -s ifconfig.me)
echo -e "${BLUE}http://$IP${NC}"
echo ""
echo -e "${YELLOW}Verificar estado del servicio:${NC}"
echo -e "${BLUE}systemctl status notify-bot${NC}"
echo ""
echo -e "${GREEN}¡El sistema está listo para usar!${NC}"
