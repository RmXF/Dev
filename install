    <script>
        // Función para toggle del menú
        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('active');
        }

        // Mostrar sección seleccionada
        function showSection(section) {
            const sections = ['dashboard', 'nueva-nota', 'historial', 'listado-notas', 'configuracion'];
            sections.forEach(s => {
                document.getElementById(s).style.display = 'none';
            });
            document.getElementById(section).style.display = 'block';
            document.getElementById('sidebar').classList.remove('active');
            
            if (section === 'dashboard') {
                loadDashboard();
            } else if (section === 'historial') {
                loadHistorial();
            } else if (section === 'listado-notas') {
                loadListado();
            }
        }

        // Cargar Dashboard
        async function loadDashboard() {
            try {
                // Cargar estado VPS
                const estadoResp = await fetch('/api/estado-vps');
                const estado = await estadoResp.json();
                document.getElementById('cpu-stat').textContent = estado.cpu + '%';
                document.getElementById('mem-stat').textContent = estado.memoria + '%';
                document.getElementById('disk-stat').textContent = estado.disco;
                document.getElementById('uptime-stat').textContent = estado.uptime;
                
                // Cargar estadísticas de notas
                const statsResp = await fetch('/api/estadisticas');
                const stats = await statsResp.json();
                document.getElementById('total-notas').textContent = stats.total;
                document.getElementById('enviadas-notas').textContent = stats.enviadas;
                document.getElementById('pendientes-notas').textContent = stats.pendientes;
            } catch (error) {
                console.error('Error cargando dashboard:', error);
            }
        }

        // Cargar Historial
        async function loadHistorial() {
            try {
                const resp = await fetch('/api/notas');
                const notas = await resp.json();
                const historial = notas.filter(n => n.enviado === true);
                
                let html = '<div style="overflow-x: auto;"><table class="notas-table"><thead><tr><th>Título</th><th>Contenido</th><th>Fecha/Hora</th><th>Enviado</th></tr></thead><tbody>';
                historial.forEach(nota => {
                    html += `<tr>
                        <td>${nota.titulo}</td>
                        <td>${nota.contenido.substring(0, 50)}...</td>
                        <td>${nota.fecha_hora}</td>
                        <td><span style="color: green;">✓ Enviado</span></td>
                    </tr>`;
                });
                html += '</tbody></table></div>';
                document.getElementById('historial-content').innerHTML = html || '<p>No hay notas en el historial</p>';
            } catch (error) {
                console.error('Error cargando historial:', error);
            }
        }

        // Cargar Listado
        async function loadListado() {
            try {
                const resp = await fetch('/api/notas');
                const notas = await resp.json();
                
                let html = '<div style="overflow-x: auto;"><table class="notas-table"><thead><tr><th>Título</th><th>Contenido</th><th>Fecha/Hora</th><th>Estado</th><th>Acciones</th></tr></thead><tbody>';
                notas.forEach(nota => {
                    html += `<tr>
                        <td>${nota.titulo}</td>
                        <td>${nota.contenido.substring(0, 50)}...</td>
                        <td>${nota.fecha_hora}</td>
                        <td>${nota.enviado ? '<span style="color: green;">✓ Enviado</span>' : '<span style="color: orange;">⏳ Pendiente</span>'}</td>
                        <td><button onclick="eliminarNota(${nota.id})" class="btn" style="background: #ff4757; color: white; padding: 5px 10px;">Eliminar</button></td>
                    </tr>`;
                });
                html += '</tbody></table></div>';
                document.getElementById('listado-content').innerHTML = html || '<p>No hay notas creadas</p>';
            } catch (error) {
                console.error('Error cargando listado:', error);
            }
        }

        // Eliminar nota
        async function eliminarNota(id) {
            if (confirm('¿Estás seguro de eliminar esta nota?')) {
                await fetch(`/api/notas/${id}`, { method: 'DELETE' });
                loadListado();
                loadDashboard();
            }
        }

        // Crear nota
        document.getElementById('nota-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const nota = {
                titulo: document.getElementById('titulo').value,
                contenido: document.getElementById('contenido').value,
                fecha_hora: document.getElementById('fecha_hora').value
            };
            
            const resp = await fetch('/api/notas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(nota)
            });
            
            if (resp.ok) {
                alert('Nota creada exitosamente');
                e.target.reset();
                loadDashboard();
            }
        });

        // Configurar bot
        document.getElementById('bot-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const config = {
                token: document.getElementById('bot-token').value,
                chat_id: document.getElementById('chat-id').value
            };
            
            const resp = await fetch('/api/configurar-bot', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(config)
            });
            
            const result = await resp.json();
            alert(result.message);
        });

        // Auto-refresh dashboard cada 30 segundos
        setInterval(() => {
            if (document.getElementById('dashboard').style.display !== 'none') {
                loadDashboard();
            }
        }, 30000);
        
        // Cargar dashboard inicial
        loadDashboard();
    </script>
</body>
</html>
EOF

# Crear script de configuración del bot
cat > /opt/notify-bot/bot_config.sh << 'EOF'
#!/bin/bash

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}======================================${NC}"
echo -e "${GREEN}   Configuración del Bot Telegram${NC}"
echo -e "${BLUE}======================================${NC}"

read -p "Ingresa el Token de tu Bot de Telegram: " BOT_TOKEN
read -p "Ingresa tu Chat ID de Telegram: " CHAT_ID

# Guardar configuración
cat > /opt/notify-bot/config.json << EOF
{
    "bot_token": "$BOT_TOKEN",
    "chat_id": "$CHAT_ID"
}
EOF

echo -e "${GREEN}✓ Configuración guardada exitosamente${NC}"

# Probar conexión
echo -e "${BLUE}Probando conexión con Telegram...${NC}"
curl -s "https://api.telegram.org/bot$BOT_TOKEN/getMe" > /dev/null

if [ $? -eq 0 ]; then
    echo -e "${GREEN}✓ Bot conectado correctamente${NC}"
else
    echo -e "${RED}✗ Error al conectar con el bot${NC}"
fi

# Reiniciar servicio
systemctl restart notify-bot
echo -e "${GREEN}✓ Servicio reiniciado${NC}"
EOF

chmod +x /opt/notify-bot/bot_config.sh

# Crear script de menú
cat > /opt/notify-bot/menu.sh << 'EOF'
#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

while true; do
    clear
    echo -e "${BLUE}╔══════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║     NOTIFYBOT - MENÚ PRINCIPAL       ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${GREEN}1.${NC} Configurar Bot de Telegram"
    echo -e "${GREEN}2.${NC} Ver estado del servicio"
    echo -e "${GREEN}3.${NC} Reiniciar servicio"
    echo -e "${GREEN}4.${NC} Ver logs"
    echo -e "${GREEN}5.${NC} Abrir panel web"
    echo -e "${GREEN}6.${NC} Ver información del sistema"
    echo -e "${RED}7.${NC} Salir"
    echo ""
    read -p "Selecciona una opción: " opcion

    case $opcion in
        1)
            /opt/notify-bot/bot_config.sh
            read -p "Presiona Enter para continuar..."
            ;;
        2)
            systemctl status notify-bot
            read -p "Presiona Enter para continuar..."
            ;;
        3)
            systemctl restart notify-bot
            echo -e "${GREEN}Servicio reiniciado${NC}"
            read -p "Presiona Enter para continuar..."
            ;;
        4)
            journalctl -u notify-bot -n 50 --no-pager
            read -p "Presiona Enter para continuar..."
            ;;
        5)
            IP=$(curl -s ifconfig.me)
            echo -e "${GREEN}Panel web disponible en: http://$IP${NC}"
            read -p "Presiona Enter para continuar..."
            ;;
        6)
            echo -e "${BLUE}Información del sistema:${NC}"
            echo "CPU: $(top -bn1 | grep 'Cpu(s)' | awk '{print $2}')%"
            echo "RAM: $(free -h | awk 'NR==2{print $3"/"$2}')"
            echo "Disco: $(df -h / | awk 'NR==2{print $5}')"
            echo "Uptime: $(uptime -p)"
            read -p "Presiona Enter para continuar..."
            ;;
        7)
            echo -e "${GREEN}¡Hasta luego!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Opción inválida${NC}"
            sleep 2
            ;;
    esac
done
EOF

chmod +x /opt/notify-bot/menu.sh

# Iniciar servicios
systemctl daemon-reload
systemctl enable notify-bot
systemctl start notify-bot
systemctl restart nginx

# Limpiar
clear

echo -e "${GREEN}======================================${NC}"
echo -e "${GREEN}¡Instalación completada exitosamente!${NC}"
echo -e "${GREEN}======================================${NC}"
echo ""
echo -e "${YELLOW}Para configurar el bot, ejecuta:${NC}"
echo -e "${BLUE}/opt/notify-bot/menu.sh${NC}"
echo ""
echo -e "${YELLOW}Para acceder al panel web:${NC}"
IP=$(curl -s ifconfig.me)
echo -e "${BLUE}http://$IP${NC}"
echo ""
echo -e "${YELLOW}Credenciales por defecto:${NC}"
echo -e "Usuario: admin"
echo -e "Contraseña: admin123"
echo ""
echo -e "${RED}¡IMPORTANTE! Cambia la contraseña después del primer inicio${NC}"
