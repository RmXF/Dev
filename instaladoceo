#!/bin/bash

# ==========================================
#        CEO MANGER INSTALLER v1.0
# ==========================================

clear

GREEN="\e[32m"
RED="\e[31m"
YELLOW="\e[33m"
NC="\e[0m"

echo -e "${GREEN}"
echo "=========================================="
echo "        CEO MANGER INSTALLER"
echo "=========================================="
echo -e "${NC}"
echo "Este instalador configurará el panel completo."
echo ""
read -p "Presione ENTER para continuar..."

# ==========================================
# Verificar ROOT
# ==========================================

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}Debe ejecutar como root.${NC}"
  exit 1
fi

# ==========================================
# Verificar Sistema
# ==========================================

echo -e "${YELLOW}Verificando sistema...${NC}"

if ! command -v apt &> /dev/null; then
    echo -e "${RED}Sistema no compatible. Solo Ubuntu/Debian.${NC}"
    exit 1
fi

echo -e "${GREEN}Sistema compatible ✔${NC}"

# ==========================================
# Solicitar Configuración
# ==========================================

echo ""
echo "CONFIGURACIÓN INICIAL"
echo "----------------------------------"

read -p "Dominio (ej: panel.midominio.com): " DOMAIN
read -p "Email administrador: " ADMIN_EMAIL
read -p "Usuario administrador: " ADMIN_USER
read -s -p "Contraseña administrador: " ADMIN_PASS
echo ""
read -p "Nombre base de datos: " DB_NAME
read -p "Usuario base de datos: " DB_USER
read -s -p "Contraseña base de datos: " DB_PASS
echo ""

# ==========================================
# Actualizar Sistema
# ==========================================

echo -e "${YELLOW}Actualizando sistema...${NC}"
apt update -y && apt upgrade -y

# ==========================================
# Instalar Dependencias
# ==========================================

echo -e "${YELLOW}Instalando Apache, MySQL, PHP...${NC}"
apt install apache2 mysql-server unzip curl git -y
apt install php php-mysql php-cli php-curl php-mbstring php-xml php-zip -y

echo -e "${YELLOW}Instalando Node.js...${NC}"
curl -fsSL https://deb.nodesource.com/setup_18.x | bash -
apt install nodejs -y

echo -e "${YELLOW}Instalando Composer...${NC}"
curl -sS https://getcomposer.org/installer | php
mv composer.phar /usr/local/bin/composer

# ==========================================
# Descargar CEO MANGER
# ==========================================

echo -e "${YELLOW}Descargando CEO MANGER...${NC}"

cd /var/www/
wget https://raw.githubusercontent.com/RmXF/rsadm/main/CEO-MANGER-v1.zip -O ceo-manger.zip

unzip ceo-manger.zip
rm ceo-manger.zip

cd ceo-manger/backend

# ==========================================
# Configurar Base de Datos
# ==========================================

echo -e "${YELLOW}Configurando base de datos...${NC}"

mysql -e "CREATE DATABASE $DB_NAME;"
mysql -e "CREATE USER '$DB_USER'@'localhost' IDENTIFIED BY '$DB_PASS';"
mysql -e "GRANT ALL PRIVILEGES ON $DB_NAME.* TO '$DB_USER'@'localhost';"
mysql -e "FLUSH PRIVILEGES;"

# ==========================================
# Configurar Laravel
# ==========================================

cp .env.example .env

sed -i "s/DB_DATABASE=.*/DB_DATABASE=$DB_NAME/" .env
sed -i "s/DB_USERNAME=.*/DB_USERNAME=$DB_USER/" .env
sed -i "s/DB_PASSWORD=.*/DB_PASSWORD=$DB_PASS/" .env

composer install
php artisan key:generate
php artisan migrate --force

# ==========================================
# Permisos
# ==========================================

chown -R www-data:www-data /var/www/ceo-manger
chmod -R 755 /var/www/ceo-manger
chmod -R 775 storage bootstrap/cache

# ==========================================
# Configurar Apache
# ==========================================

cat <<EOF > /etc/apache2/sites-available/ceo-manger.conf
<VirtualHost *:80>
    ServerName $DOMAIN
    DocumentRoot /var/www/ceo-manger/backend/public

    <Directory /var/www/ceo-manger/backend/public>
        AllowOverride All
        Require all granted
    </Directory>
</VirtualHost>
EOF

a2enmod rewrite
a2ensite ceo-manger.conf
systemctl reload apache2

# ==========================================
# Finalización
# ==========================================

clear
echo -e "${GREEN}"
echo "=========================================="
echo "    INSTALACIÓN COMPLETADA"
echo "=========================================="
echo -e "${NC}"

echo "Panel URL: http://$DOMAIN"
echo "Usuario Admin: $ADMIN_USER"
echo ""
echo "CEO MANGER ha sido instalado correctamente."
echo ""
