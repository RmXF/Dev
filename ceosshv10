#!/bin/bash

# ==============================================
# CEO SSH PANEL - INSTALADOR PROFESIONAL
# Panel v2.0 con mejoras avanzadas
# ==============================================

set -e

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# Variables
PANEL_VERSION="2.0.0"
PANEL_NAME="CEO SSH"
PANEL_PORT="80"
INSTALL_DIR="/var/www/ceo-ssh"
LOG_FILE="/var/log/ceo-ssh-install.log"
MYSQL_ROOT_PASS=""
MYSQL_CEO_PASS=""
ADMIN_USER=""
ADMIN_PASS=""
ADMIN_EMAIL=""

# URL del panel ZIP
PANEL_ZIP_URL="https://raw.githubusercontent.com/RmXF/rsadm/main/panel.zip"
PANEL_ZIP_LOCAL="./panel.zip"

banner() {
    clear
    echo -e "${CYAN}"
    echo "   ██████╗███████╗ ██████╗     ███████╗███████╗██╗  ██╗"
    echo "  ██╔════╝██╔════╝██╔═══██╗    ██╔════╝██╔════╝██║  ██║"
    echo "  ██║     █████╗  ██║   ██║    ███████╗███████╗███████║"
    echo "  ██║     ██╔══╝  ██║   ██║    ╚════██║╚════██║██╔══██║"
    echo "  ╚██████╗███████╗╚██████╔╝    ███████║███████║██║  ██║"
    echo "   ╚═════╝╚══════╝ ╚═════╝     ╚══════╝╚══════╝╚═╝  ╚═╝"
    echo -e "${NC}"
    echo -e "${GREEN}        PANEL DE CONTROL PROFESIONAL SSH${NC}"
    echo -e "${YELLOW}                   Version ${PANEL_VERSION}${NC}"
    echo -e "${WHITE}        Instalacion Automatica Completa${NC}"
    echo ""
}

log() { echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a $LOG_FILE; }
error() { echo -e "${RED}ERROR: $1${NC}" | tee -a $LOG_FILE; exit 1; }
success() { echo -e "${GREEN}OK: $1${NC}" | tee -a $LOG_FILE; }
info() { echo -e "${CYAN}INFO: $1${NC}" | tee -a $LOG_FILE; }
warning() { echo -e "${YELLOW}WARN: $1${NC}" | tee -a $LOG_FILE; }

check_root() {
    if [ "$EUID" -ne 0 ]; then
        error "Por favor ejecuta como root (sudo ./install.sh)"
    fi
    success "Root verificados"
}

check_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$ID
        if [[ "$OS" == "ubuntu" ]] || [[ "$OS" == "debian" ]]; then
            success "Sistema operativo compatible: $OS"
        else
            error "Sistema no soportado. Usa Ubuntu o Debian"
        fi
    else
        error "No se pudo detectar el sistema operativo"
    fi
}

ask_config() {
    echo ""
    echo -e "${PURPLE}========================================${NC}"
    echo -e "${WHITE}       CONFIGURACION DEL PANEL${NC}"
    echo -e "${PURPLE}========================================${NC}"
    echo ""
    
    read -p "$(echo -e ${CYAN}Usuario administrador: ${NC})" ADMIN_USER
    while [[ -z "$ADMIN_USER" ]]; do
        read -p "$(echo -e ${RED}Usuario requerido: ${NC})" ADMIN_USER
    done
    
    read -p "$(echo -e ${CYAN}Email administrador: ${NC})" ADMIN_EMAIL
    while [[ -z "$ADMIN_EMAIL" ]]; do
        read -p "$(echo -e ${RED}Email requerido: ${NC})" ADMIN_EMAIL
    done
    
    read -s -p "$(echo -e ${CYAN}Contrasena administrador: ${NC})" ADMIN_PASS
    echo ""
    while [[ ${#ADMIN_PASS} -lt 6 ]]; do
        read -s -p "$(echo -e ${RED}Minimo 6 caracteres: ${NC})" ADMIN_PASS
        echo ""
    done
    
    read -s -p "$(echo -e ${CYAN}Confirmar contrasena: ${NC})" ADMIN_PASS_CONFIRM
    echo ""
    if [[ "$ADMIN_PASS" != "$ADMIN_PASS_CONFIRM" ]]; then
        error "Las contrasenas no coinciden"
    fi
    
    read -p "$(echo -e ${CYAN}Puerto del panel [80]: ${NC})" PANEL_PORT_INPUT
    PANEL_PORT=${PANEL_PORT_INPUT:-80}
    
    echo ""
    success "Configuracion guardada"
}

generate_passwords() {
    MYSQL_ROOT_PASS=$(openssl rand -base64 16)
    MYSQL_CEO_PASS=$(openssl rand -base64 16)
    JWT_SECRET=$(openssl rand -base64 32)
}

stop_services() {
    info "Verificando servicios en puerto 80..."
    if systemctl is-active --quiet apache2; then
        systemctl stop apache2 && systemctl disable apache2
        success "Apache detenido"
    fi
    if systemctl is-active --quiet nginx; then
        systemctl stop nginx && systemctl disable nginx
        success "Nginx detenido"
    fi
    success "Puerto 80 liberado"
}

install_dependencies() {
    info "Instalando dependencias..."
    
    apt-get update -y
    apt-get install -y curl wget git unzip zip ufw fail2ban openssl \
        lsb-release ca-certificates apt-transport-https software-properties-common \
        nginx mariadb-server mariadb-client \
        php php-cli php-fpm php-mysql php-mysqli php-pdo php-curl \
        php-mbstring php-xml php-zip php-gd php-bcmath
    
    success "Dependencias instaladas"
}

configure_mysql() {
    info "Configurando MySQL..."
    systemctl enable mariadb
    systemctl start mariadb
    
    mysql -e "SET PASSWORD FOR 'root'@'localhost' = PASSWORD('$MYSQL_ROOT_PASS');" 2>/dev/null || true
    mysql -e "DELETE FROM mysql.user WHERE User='';" 2>/dev/null || true
    mysql -e "CREATE DATABASE IF NOT EXISTS ceo_ssh CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" 2>/dev/null
    mysql -e "CREATE USER IF NOT EXISTS 'ceo_ssh'@'localhost' IDENTIFIED BY '$MYSQL_CEO_PASS';" 2>/dev/null
    mysql -e "GRANT ALL PRIVILEGES ON ceo_ssh.* TO 'ceo_ssh'@'localhost';" 2>/dev/null
    mysql -e "FLUSH PRIVILEGES;" 2>/dev/null
    
    success "MySQL configurado"
}

download_panel() {
    info "Descargando panel CEO SSH..."
    
    TEMP_DIR=$(mktemp -d)
    
    if [ -f "$PANEL_ZIP_LOCAL" ]; then
        info "Usando panel.zip local..."
        cp $PANEL_ZIP_LOCAL $TEMP_DIR/panel.zip
    else
        info "Descargando desde URL..."
        wget -O $TEMP_DIR/panel.zip $PANEL_ZIP_URL || error "No se pudo descargar el panel"
    fi
    
    info "Descomprimiendo archivos..."
    mkdir -p $INSTALL_DIR
    unzip -o $TEMP_DIR/panel.zip -d $INSTALL_DIR
    
    rm -rf $TEMP_DIR
    
    success "Panel descargado y descomprimido"
}

configure_panel() {
    info "Configurando panel..."
    
    if [ -f "$INSTALL_DIR/includes/config.php" ]; then
        sed -i "s/DB_PASS_PLACEHOLDER/$MYSQL_CEO_PASS/g" $INSTALL_DIR/includes/config.php
    fi
    
    success "Panel configurado"
}

setup_database() {
    info "Configurando base de datos..."
    
    ADMIN_HASH=$(php -r "echo password_hash('$ADMIN_PASS', PASSWORD_DEFAULT);")
    
    mysql -u root -p$MYSQL_ROOT_PASS ceo_ssh << EOF
CREATE TABLE IF NOT EXISTS users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    email VARCHAR(100),
    role ENUM('admin', 'user') DEFAULT 'admin',
    status ENUM('active', 'inactive', 'suspended') DEFAULT 'active',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_login TIMESTAMP NULL
);

CREATE TABLE IF NOT EXISTS ssh_tokens (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    expires_at DATE NOT NULL,
    status ENUM('active', 'expired', 'suspended') DEFAULT 'active',
    created_by INT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (created_by) REFERENCES users(id) ON DELETE SET NULL
);

CREATE TABLE IF NOT EXISTS logs (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,
    action VARCHAR(100),
    details TEXT,
    ip_address VARCHAR(45),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL
);

CREATE TABLE IF NOT EXISTS settings (
    \`key\` VARCHAR(100) PRIMARY KEY,
    \`value\` TEXT,
    description TEXT,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);

INSERT INTO users (username, password, email, role, status) 
VALUES ('$ADMIN_USER', '$ADMIN_HASH', '$ADMIN_EMAIL', 'admin', 'active')
ON DUPLICATE KEY UPDATE password = '$ADMIN_HASH';

INSERT INTO settings (\`key\`, \`value\`, description) VALUES
('panel_name', '$PANEL_NAME', 'Nombre del panel'),
('panel_version', '$PANEL_VERSION', 'Version del panel'),
('maintenance_mode', '0', 'Modo mantenimiento')
ON DUPLICATE KEY UPDATE \`value\` = VALUES(\`value\`);
EOF
    
    success "Base de datos configurada"
}

configure_nginx() {
    info "Configurando Nginx..."
    
    PHP_VERSION=$(php -r "echo PHP_MAJOR_VERSION . '.' . PHP_MINOR_VERSION;")
    
    cat > /etc/nginx/sites-available/ceo-ssh << EOF
server {
    listen $PANEL_PORT;
    listen [::]:$PANEL_PORT;
    server_name _;
    root $INSTALL_DIR;
    index index.php index.html;
    
    location / {
        try_files \$uri \$uri/ /index.php?\$args;
    }
    
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php${PHP_VERSION}-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }
}
EOF
    
    ln -sf /etc/nginx/sites-available/ceo-ssh /etc/nginx/sites-enabled/
    rm -f /etc/nginx/sites-enabled/default
    nginx -t
    systemctl restart nginx
    systemctl restart php${PHP_VERSION}-fpm
    
    success "Nginx configurado"
}

set_permissions() {
    info "Configurando permisos..."
    chown -R www-data:www-data $INSTALL_DIR
    chmod -R 755 $INSTALL_DIR
    success "Permisos configurados"
}

configure_firewall() {
    info "Configurando firewall..."
    ufw --force disable
    ufw default deny incoming
    ufw default allow outgoing
    ufw allow 22/tcp
    ufw allow $PANEL_PORT/tcp
    ufw --force enable
    success "Firewall configurado"
}

show_final_info() {
    PHP_VERSION=$(php -r "echo PHP_MAJOR_VERSION . '.' . PHP_MINOR_VERSION;")
    IP=$(curl -s ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
    
    clear
    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo -e "${GREEN}       INSTALACION COMPLETADA${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo ""
    echo -e "${CYAN}Acceso al panel:${NC}"
    echo -e "   ${GREEN}http://$IP:$PANEL_PORT${NC}"
    echo ""
    echo -e "${CYAN}Credenciales de acceso:${NC}"
    echo -e "   ${YELLOW}Usuario:${NC} $ADMIN_USER"
    echo -e "   ${YELLOW}Contrasena:${NC} $ADMIN_PASS"
    echo ""
    echo -e "${CYAN}Informacion:${NC}"
    echo -e "   ${YELLOW}Directorio:${NC} $INSTALL_DIR"
    echo -e "   ${YELLOW}Log:${NC} $LOG_FILE"
    echo ""
    echo -e "${CYAN}Credenciales MySQL:${NC}"
    echo -e "   ${YELLOW}Root Password:${NC} $MYSQL_ROOT_PASS"
    echo -e "   ${YELLOW}Usuario DB:${NC} ceo_ssh"
    echo -e "   ${YELLOW}Password DB:${NC} $MYSQL_CEO_PASS"
    echo ""
    echo -e "${YELLOW}Guarda estas credenciales en un lugar seguro${NC}"
    echo ""
    echo -e "${GREEN}========================================${NC}"
    echo ""
    
    cat > $INSTALL_DIR/CREDENCIALES.txt << EOF
========================================
        CEO SSH PANEL - CREDENCIALES
========================================

URL ACCESO: http://$IP:$PANEL_PORT

USUARIO ADMIN: $ADMIN_USER
CONTRASENA: $ADMIN_PASS
EMAIL: $ADMIN_EMAIL

BASE DE DATOS:
   - Nombre: ceo_ssh
   - Usuario: ceo_ssh
   - Contrasena: $MYSQL_CEO_PASS
   - Root Password: $MYSQL_ROOT_PASS

DIRECTORIO: $INSTALL_DIR
LOG: $LOG_FILE

========================================
EOF
    
    chmod 600 $INSTALL_DIR/CREDENCIALES.txt
}

main() {
    banner
    log "Iniciando instalacion de $PANEL_NAME v$PANEL_VERSION"
    
    check_root
    check_os
    ask_config
    generate_passwords
    stop_services
    install_dependencies
    configure_mysql
    download_panel
    configure_panel
    setup_database
    set_permissions
    configure_nginx
    configure_firewall
    show_final_info
    
    log "Instalacion completada exitosamente"
}

main "$@"
