instalar_panel_nextjs() {
    clear
    echo -e "$bar1"
    echo -e "${verde}     🚀 PANEL ULTRA AVANZADO - ONLYCODE VPN PRO${cierre}"
    echo -e "$bar1"
    
    # Verificar root
