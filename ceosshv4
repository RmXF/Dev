        return 1
    fi
    
    # Solicitar configuración
    echo -e "${amarillo}⚙️  Configuración del Panel${cierre}"
    echo -e "$bar2"
    read -p "Usuario admin [admin]: " ADMIN_USER
    ADMIN_USER=${ADMIN_USER:-admin}
    read -s -p "Contraseña admin [admin123]: " ADMIN_PASS
    echo
    ADMIN_PASS=${ADMIN_PASS:-admin123}
    read -p "Puerto del panel [3000]: " PANEL_PORT
    PANEL_PORT=${PANEL_PORT:-3000}
    read -p "Puerto API [8080]: " API_PORT
    API_PORT=${API_PORT:-8080}
    
    echo -e "\n${amarillo}📦 Instalando dependencias necesarias...${cierre}"
    
    # Instalar Node.js 18+
    curl -fsSL https://deb.nodesource.com/setup_18.x | bash - >/dev/null 2>&1
    apt-get install -y nodejs >/dev/null 2>&1
    
    # Instalar PM2 globalmente
    npm install -g pm2 >/dev/null 2>&1
    
    # Instalar PHP y dependencias
    apt-get install -y php php-cli php-curl php-json php-sqlite3 php-zip unzip wget curl git >/dev/null 2>&1
    
    echo -e "${verde}✅ Dependencias instaladas${cierre}"
    
    # Crear directorios
    PANEL_DIR="/var/www/onlycode-panel"
    API_DIR="/var/www/onlycode-api"
    BACKUP_DIR="/root/panel-backup"
    
    # Limpiar directorios anteriores si existen
    if [ -d "$PANEL_DIR" ]; then
        echo -e "${amarillo}📦 Creando backup del panel anterior...${cierre}"
        mkdir -p $BACKUP_DIR
        mv $PANEL_DIR $BACKUP_DIR/panel-backup-$(date +%Y%m%d-%H%M%S)
    fi
    
    mkdir -p $PANEL_DIR $API_DIR
    
    echo -e "${amarillo}📥 Descargando Panel Ultra Avanzado...${cierre}"
    
    # URL DEL ZIP - CAMBIA ESTA URL POR LA UBICACIÓN DE TU ZIP
    # Ejemplo: https://tu-dominio.com/panel-onlycode.zip
    # O usando Dropbox: https://www.dropbox.com/s/xxxxx/panel-onlycode.zip?dl=1
    ZIP_URL="https://raw.githubusercontent.com/RmXF/Dev/main/panel-onlycode.zip"
    
    # Intentar descargar el ZIP
    wget -O /tmp/panel-onlycode.zip "$ZIP_URL" 2>/dev/null
    
    if [ $? -ne 0 ] || [ ! -s /tmp/panel-onlycode.zip ]; then
        echo -e "${rojo}❌ No se pudo descargar el panel desde: $ZIP_URL${cierre}"
        echo -e "${amarillo}📌 Por favor, introduce la URL de tu ZIP:${cierre}"
        read -p "URL del ZIP: " CUSTOM_URL
        if [ -n "$CUSTOM_URL" ]; then
            wget -O /tmp/panel-onlycode.zip "$CUSTOM_URL" 2>/dev/null
        fi
        
        if [ ! -s /tmp/panel-onlycode.zip ]; then
            echo -e "${rojo}❌ No se pudo descargar el panel. Instalación cancelada${cierre}"
            return 1
        fi
    fi
    
    # Verificar que es un ZIP válido
    if ! file /tmp/panel-onlycode.zip | grep -q "Zip archive"; then
        echo -e "${rojo}❌ El archivo descargado no es un ZIP válido${cierre}"
        rm -f /tmp/panel-onlycode.zip
        return 1
    fi
    
    echo -e "${amarillo}📦 Descomprimiendo archivos del panel...${cierre}"
    
    # Descomprimir el panel
    unzip -o /tmp/panel-onlycode.zip -d $PANEL_DIR >/dev/null 2>&1
    
    if [ $? -ne 0 ]; then
        echo -e "${rojo}❌ Error al descomprimir el ZIP${cierre}"
        rm -f /tmp/panel-onlycode.zip
        return 1
    fi
    
    # Verificar si se descomprimió correctamente y tiene package.json
    if [ ! -f "$PANEL_DIR/package.json" ]; then
        # Buscar si el ZIP tenía una carpeta raíz
        SUBDIR=$(find $PANEL_DIR -maxdepth 2 -name "package.json" -type f | head -1 | xargs dirname 2>/dev/null)
        if [ -n "$SUBDIR" ] && [ "$SUBDIR" != "$PANEL_DIR" ]; then
            echo -e "${amarillo}📁 Moviendo archivos desde subdirectorio...${cierre}"
            mv $SUBDIR/* $PANEL_DIR/ 2>/dev/null
            mv $SUBDIR/.[!.]* $PANEL_DIR/ 2>/dev/null
            rmdir $SUBDIR 2>/dev/null
        else
            echo -e "${rojo}❌ El ZIP no contiene un panel válido (package.json no encontrado)${cierre}"
            rm -f /tmp/panel-onlycode.zip
            return 1
        fi
    fi
    
    rm -f /tmp/panel-onlycode.zip
    echo -e "${verde}✅ Panel descomprimido correctamente${cierre}"
    
    # Guardar credenciales del panel
    echo "$ADMIN_USER:$ADMIN_PASS" > /etc/onlycode-panel-auth
    chmod 600 /etc/onlycode-panel-auth
    
    # ==============================================
    # CREAR API PHP (Siempre se crea fresca)
    # ==============================================
    echo -e "${amarillo}🔧 Configurando API PHP...${cierre}"
    
    cat > $API_DIR/index.php << 'PHPAPI'
<?php
header('Content-Type: application/json');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: GET, POST, PUT, DELETE');
header('Access-Control-Allow-Headers: Content-Type, Authorization');

define('TOKEN_FILE', '/etc/token/BD');
define('CLIENT_FILE', '/etc/token/.clientes');
define('LIMITS_FILE', '/etc/token/limits');

function authenticate() {
    $headers = getallheaders();
    if (!isset($headers['Authorization'])) {
        http_response_code(401);
        echo json_encode(['error' => 'No autorizado']);
        exit;
    }
    
    $auth = base64_decode(str_replace('Basic ', '', $headers['Authorization']));
    list($user, $pass) = explode(':', $auth);
    
    $panel_auth = file_get_contents('/etc/onlycode-panel-auth');
    $creds = explode(':', $panel_auth);
    
    if ($user !== trim($creds[0]) || $pass !== trim($creds[1])) {
        http_response_code(401);
        echo json_encode(['error' => 'Credenciales inválidas']);
        exit;
    }
    return true;
}

function getLimits() {
    $limits = [];
    if (file_exists(LIMITS_FILE)) {
        $lines = file(LIMITS_FILE, FILE_IGNORE_NEW_LINES);
        foreach ($lines as $line) {
            if (strpos($line, ':') !== false) {
                list($user, $limit) = explode(':', $line);
                $limits[$user] = (int)$limit;
            }
        }
    }
    return $limits;
}

function saveLimit($username, $limit) {
    $limits = getLimits();
    $limits[$username] = $limit;
    $content = '';
    foreach ($limits as $user => $lim) {
        $content .= "$user:$lim\n";
    }
    file_put_contents(LIMITS_FILE, $content);
}

function getActiveConnections($username) {
    $count = 0;
    $log = file_exists('/var/log/auth.log') ? '/var/log/auth.log' : '/var/log/secure';
    if (file_exists($log)) {
        $output = shell_exec("grep -c 'Accepted password for $username' $log 2>/dev/null");
        $count = (int)$output;
    }
    return $count;
}

function getUsers() {
    $users = [];
    $limits = getLimits();
    if (file_exists(TOKEN_FILE)) {
        $tokens = array_filter(file(TOKEN_FILE, FILE_IGNORE_NEW_LINES));
        foreach ($tokens as $token) {
            $token = trim($token);
            if (empty($token)) continue;
            
            $user_data = shell_exec("chage -l $token 2>/dev/null");
            if ($user_data) {
                preg_match('/Account expires.*: (.+)$/m', $user_data, $exp_match);
                $expires = trim($exp_match[1] ?? 'never');
                $active_cons = getActiveConnections($token);
                $max_cons = $limits[$token] ?? 1;
                
                $users[] = [
                    'username' => $token,
                    'expiration' => $expires,
                    'status' => ($expires === 'never' || strtotime($expires) > time()) ? 'active' : 'inactive',
                    'active_connections' => $active_cons,
                    'max_connections' => $max_cons,
                    'limit_reached' => $active_cons >= $max_cons
                ];
            }
        }
    }
    return $users;
}

function createUser($username, $password, $days, $max_connections) {
    $check = shell_exec("id $username 2>/dev/null");
    if ($check) return ['error' => 'Usuario ya existe'];
    
    $exp_date = date('Y-m-d', strtotime("+$days days"));
    $create = shell_exec("useradd -m -s /bin/false -e $exp_date $username 2>&1");
    if ($create) return ['error' => $create];
    
    shell_exec("echo '$username:$password' | chpasswd");
    file_put_contents(TOKEN_FILE, $username . "\n", FILE_APPEND);
    saveLimit($username, $max_connections);
    
    $date = date('d/m/Y');
    $time = date('H:i');
    file_put_contents(CLIENT_FILE, "$username $username $date $time\n", FILE_APPEND);
    
    return [
        'success' => true,
        'username' => $username,
        'password' => $password,
        'expiration' => $exp_date,
        'days' => $days,
        'max_connections' => $max_connections
    ];
}

function deleteUser($username) {
    shell_exec("userdel -r -f $username 2>&1");
    
    if (file_exists(TOKEN_FILE)) {
        $tokens = file(TOKEN_FILE, FILE_IGNORE_NEW_LINES);
        $tokens = array_filter($tokens, fn($t) => trim($t) !== $username);
        file_put_contents(TOKEN_FILE, implode("\n", $tokens) . "\n");
    }
    
    if (file_exists(LIMITS_FILE)) {
        $limits = getLimits();
        unset($limits[$username]);
        $content = '';
        foreach ($limits as $user => $lim) {
            $content .= "$user:$lim\n";
        }
        file_put_contents(LIMITS_FILE, $content);
    }
    
    if (file_exists(CLIENT_FILE)) {
        $clients = file(CLIENT_FILE, FILE_IGNORE_NEW_LINES);
        $clients = array_filter($clients, fn($c) => strpos($c, $username) !== 0);
        file_put_contents(CLIENT_FILE, implode("\n", $clients) . "\n");
    }
    
    return ['success' => true];
}

function extendUser($username, $days) {
    $current_exp = shell_exec("chage -l $username | grep 'Account expires' | cut -d: -f2");
    $current_exp = trim($current_exp);
    
    if ($current_exp === 'never' || empty($current_exp)) {
        $new_exp = date('Y-m-d', strtotime("+$days days"));
    } else {
        $current_timestamp = strtotime($current_exp);
        if ($current_timestamp < time()) {
            $new_timestamp = time() + ($days * 86400);
        } else {
            $new_timestamp = $current_timestamp + ($days * 86400);
        }
        $new_exp = date('Y-m-d', $new_timestamp);
    }
    
    shell_exec("usermod -e $new_exp $username");
    return ['success' => true, 'new_expiration' => $new_exp];
}

function updateLimit($username, $max_connections) {
    saveLimit($username, $max_connections);
    return ['success' => true, 'max_connections' => $max_connections];
}

function getStats() {
    $total_users = shell_exec("cat /etc/passwd | grep -c '/home'");
    $online_users = shell_exec("ps aux | grep -E 'sshd|dropbear' | grep -v grep | wc -l");
    $load = sys_getloadavg();
    
    $meminfo = file_get_contents('/proc/meminfo');
    preg_match('/MemTotal:\s+(\d+)/', $meminfo, $mem_total);
    preg_match('/MemAvailable:\s+(\d+)/', $meminfo, $mem_avail);
    $mem_used = $mem_total[1] - $mem_avail[1];
    
    return [
        'total_users' => (int)$total_users,
        'online_users' => (int)$online_users,
        'server_load' => round($load[0], 2),
        'cpu_usage' => round($load[0] * 10, 2),
        'disk_usage' => disk_free_space('/') ? round(100 - (disk_free_space('/') / disk_total_space('/') * 100), 2) : 0,
        'memory_total' => round($mem_total[1] / 1024 / 1024, 2),
        'memory_used' => round($mem_used / 1024 / 1024, 2),
        'memory_percent' => round(($mem_used / $mem_total[1]) * 100, 2)
    ];
}

