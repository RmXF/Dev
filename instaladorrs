NC='\033[0m' # No Color

# Configuración
GITHUB_ZIP_URL="https://github.com/tuusuario/turepositorio/raw/main/vortex-website.zip"
INSTALL_DIR="/var/www/vortex"
NGINX_CONF="/etc/nginx/sites-available/vortex"
APACHE_CONF="/etc/apache2/sites-available/vortex.conf"
LOG_FILE="/tmp/vortex-install-$(date +%Y%m%d-%H%M%S).log"

