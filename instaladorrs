# Función para loguear
log() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}[ERROR] $1${NC}" | tee -a "$LOG_FILE"
    exit 1
}

warning() {
    echo -e "${YELLOW}[WARNING] $1${NC}" | tee -a "$LOG_FILE"
}

# Función para detectar el sistema operativo
detect_os() {
    log "🔍 Detectando sistema operativo..."
    
    if [[ "$OSTYPE" == "linux-gnu"* ]]; then
        if [ -f /etc/os-release ]; then
            . /etc/os-release
            OS=$ID
            VER=$VERSION_ID
            log "✅ Sistema detectado: Linux - $PRETTY_NAME"
        else
            OS="linux"
            log "✅ Sistema detectado: Linux (genérico)"
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        OS="macos"
        VER=$(sw_vers -productVersion)
        log "✅ Sistema detectado: macOS $VER"
    else
        error "Sistema operativo no soportado: $OSTYPE"
    fi
}

# Función para instalar dependencias según el OS
install_dependencies() {
    log "📦 Instalando dependencias necesarias..."
    
    case $OS in
        ubuntu|debian)
            log "📥 Actualizando repositorios..."
            apt-get update -y >> "$LOG_FILE" 2>&1
            
            log "📥 Instalando Apache, Nginx, PHP, y utilidades..."
            apt-get install -y \
                apache2 \
                nginx \
                php \
                php-fpm \
                php-mysql \
                php-curl \
                php-json \
                php-mbstring \
                php-xml \
                php-zip \
                curl \
                wget \
                git \
                unzip \
                zip \
                htop \
                net-tools \
                ufw \
                certbot \
                python3-certbot-apache \
                python3-certbot-nginx \
                >> "$LOG_FILE" 2>&1
            ;;
            
        centos|fedora|rhel)
            log "📥 Instalando EPEL y actualizando..."
            if [[ "$OS" == "centos" ]] || [[ "$OS" == "rhel" ]]; then
                yum install -y epel-release >> "$LOG_FILE" 2>&1
            fi
            
            log "📥 Instalando Apache, Nginx, PHP, y utilidades..."
            if [[ "$OS" == "fedora" ]]; then
                dnf install -y \
                    httpd \
                    nginx \
                    php \
                    php-fpm \
                    php-mysqlnd \
                    php-curl \
                    php-json \
                    php-mbstring \
                    php-xml \
                    php-zip \
                    curl \
                    wget \
                    git \
                    unzip \
                    zip \
                    htop \
                    net-tools \
                    firewalld \
                    certbot \
                    python3-certbot-apache \
                    python3-certbot-nginx \
                    >> "$LOG_FILE" 2>&1
            else
                yum install -y \
                    httpd \
                    nginx \
                    php \
                    php-fpm \
                    php-mysqlnd \
                    php-curl \
                    php-json \
                    php-mbstring \
                    php-xml \
                    php-zip \
                    curl \
                    wget \
                    git \
                    unzip \
                    zip \
                    htop \
                    net-tools \
                    firewalld \
                    certbot \
                    python3-certbot-apache \
                    python3-certbot-nginx \
                    >> "$LOG_FILE" 2>&1
            fi
            ;;
            
        macos)
            log "📥 Instalando Homebrew si no está presente..."
            if ! command -v brew &> /dev/null; then
                /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" >> "$LOG_FILE" 2>&1
            fi
            
            log "📥 Instalando paquetes con Homebrew..."
            brew install \
                httpd \
                nginx \
                php \
                wget \
                git \
                unzip \
                zip \
                htop \
                >> "$LOG_FILE" 2>&1
            ;;
    esac
    
    log "✅ Dependencias instaladas correctamente"
}

# Función para configurar firewall
configure_firewall() {
    log "🛡️ Configurando firewall..."
    
    case $OS in
        ubuntu|debian)
            ufw allow 22/tcp comment 'SSH' >> "$LOG_FILE" 2>&1
            ufw allow 80/tcp comment 'HTTP' >> "$LOG_FILE" 2>&1
            ufw allow 443/tcp comment 'HTTPS' >> "$LOG_FILE" 2>&1
            ufw --force enable >> "$LOG_FILE" 2>&1
            ;;
            
        centos|fedora|rhel)
            systemctl start firewalld >> "$LOG_FILE" 2>&1
            systemctl enable firewalld >> "$LOG_FILE" 2>&1
            firewall-cmd --permanent --add-service=ssh >> "$LOG_FILE" 2>&1
            firewall-cmd --permanent --add-service=http >> "$LOG_FILE" 2>&1
            firewall-cmd --permanent --add-service=https >> "$LOG_FILE" 2>&1
            firewall-cmd --reload >> "$LOG_FILE" 2>&1
            ;;
            
        macos)
            log "📝 macOS: Configura firewall manualmente en Preferencias del Sistema > Seguridad y Privacidad > Firewall"
            ;;
    esac
    
    log "✅ Firewall configurado correctamente"
}

# Función para descargar el sitio web
download_website() {
    log "📥 Descargando sitio web desde GitHub..."
    
    # Crear directorio de instalación
    mkdir -p "$INSTALL_DIR"
    
    # Descargar ZIP
    wget -O /tmp/vortex-website.zip "$GITHUB_ZIP_URL" >> "$LOG_FILE" 2>&1
    
    if [ $? -ne 0 ]; then
        error "No se pudo descargar el archivo desde GitHub"
    fi
    
    # Descomprimir
    unzip /tmp/vortex-website.zip -d "$INSTALL_DIR" >> "$LOG_FILE" 2>&1
    
    if [ $? -ne 0 ]; then
        error "No se pudo descomprimir el archivo"
    fi
    
    # Limpiar
    rm /tmp/vortex-website.zip
    
    log "✅ Sitio web descargado en: $INSTALL_DIR"
}

# Función para configurar Nginx
setup_nginx() {
    log "🌐 Configurando Nginx..."
    
    # Obtener IP del servidor
    SERVER_IP=$(curl -s ifconfig.me)
    
    # Crear configuración de Nginx
    cat > "$NGINX_CONF" << EOF
server {
    listen 80;
    listen [::]:80;
    
    server_name $SERVER_IP;
    
    root $INSTALL_DIR;
    index index.html index.htm;
    
    # Logs
    access_log /var/log/nginx/vortex_access.log;
    error_log /var/log/nginx/vortex_error.log;
    
    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/xml+rss application/json;
    
    # Cache estático
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
    
    location / {
        try_files \$uri \$uri/ =404;
    }
    
    # Seguridad básica
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
}
EOF
    
    # Habilitar el sitio
    ln -sf "$NGINX_CONF" /etc/nginx/sites-enabled/ >> "$LOG_FILE" 2>&1
    
    # Probar configuración
    nginx -t >> "$LOG_FILE" 2>&1
    
    if [ $? -eq 0 ]; then
        systemctl restart nginx >> "$LOG_FILE" 2>&1
        systemctl enable nginx >> "$LOG_FILE" 2>&1
        log "✅ Nginx configurado correctamente"
    else
        error "Error en la configuración de Nginx"
    fi
}

# Función para configurar Apache (alternativa)
setup_apache() {
    log "🌐 Configurando Apache..."
    
    # Obtener IP del servidor
    SERVER_IP=$(curl -s ifconfig.me)
    
    # Crear configuración de Apache
    cat > "$APACHE_CONF" << EOF
<VirtualHost *:80>
    ServerName $SERVER_IP
    
    DocumentRoot $INSTALL_DIR
    
    <Directory $INSTALL_DIR>
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted
    </Directory>
    
    ErrorLog \${APACHE_LOG_DIR}/vortex_error.log
    CustomLog \${APACHE_LOG_DIR}/vortex_access.log combined
    
    # Compresión
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
    
    # Cache
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</VirtualHost>
EOF
    
    # Habilitar el sitio y módulos necesarios
    a2ensite vortex.conf >> "$LOG_FILE" 2>&1
    a2dissite 000-default.conf >> "$LOG_FILE" 2>&1
    a2enmod rewrite >> "$LOG_FILE" 2>&1
    a2enmod headers >> "$LOG_FILE" 2>&1
    a2enmod deflate >> "$LOG_FILE" 2>&1
    a2enmod expires >> "$LOG_FILE" 2>&1
    
    # Probar configuración
    apache2ctl configtest >> "$LOG_FILE" 2>&1
    
    if [ $? -eq 0 ]; then
        systemctl restart apache2 >> "$LOG_FILE" 2>&1
        systemctl enable apache2 >> "$LOG_FILE" 2>&1
        log "✅ Apache configurado correctamente"
    else
        error "Error en la configuración de Apache"
    fi
}

# Función para configurar HTTPS con Let's Encrypt
setup_https() {
    log "🔐 Configurando HTTPS con Let's Encrypt..."
    
    SERVER_IP=$(curl -s ifconfig.me)
    DOMAIN=$(hostname -f)
    
    echo ""
    echo -e "${YELLOW}⚠️  IMPORTANTE: Para HTTPS necesitas un dominio válido${NC}"
    echo -e "Tu IP actual es: ${GREEN}$SERVER_IP${NC}"
    echo -e "Tu hostname es: ${GREEN}$DOMAIN${NC}"
    echo ""
    read -p "¿Quieres configurar HTTPS con Let's Encrypt? (s/n): " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Ss]$ ]]; then
        read -p "Introduce tu dominio (ejemplo: midominio.com): " DOMAIN
        
        case $WEBSERVER in
            nginx)
                certbot --nginx -d "$DOMAIN" --non-interactive --agree-tos --email admin@"$DOMAIN" >> "$LOG_FILE" 2>&1
                ;;
            apache)
                certbot --apache -d "$DOMAIN" --non-interactive --agree-tos --email admin@"$DOMAIN" >> "$LOG_FILE" 2>&1
                ;;
        esac
        
        if [ $? -eq 0 ]; then
            log "✅ HTTPS configurado correctamente para $DOMAIN"
            
            # Configurar renovación automática
            (crontab -l 2>/dev/null; echo "0 0 * * * certbot renew --quiet") | crontab -
            log "✅ Renovación automática configurada"
        else
            warning "No se pudo configurar HTTPS. Puedes intentarlo manualmente después"
        fi
    else
        log "📝 HTTPS no configurado. Continuando con HTTP"
    fi
}

