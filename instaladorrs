# Función principal
main() {
    show_banner
    
    # Preguntar por el servidor web
    echo -e "${CYAN}¿Qué servidor web quieres usar?${NC}"
    echo "1) Nginx (Recomendado - Más rápido)"
    echo "2) Apache (Más compatible)"
    read -p "Selecciona una opción (1-2): " WEBSERVER
    
    case $WEBSERVER in
        1) WEBSERVER="nginx" ;;
        2) WEBSERVER="apache" ;;
        *) WEBSERVER="nginx" ;;
    esac
    
    # Preguntar por el ZIP de GitHub
    echo ""
    echo -e "${YELLOW}⚠️  IMPORTANTE:${NC}"
    echo "Antes de continuar, asegúrate de haber subido tu archivo ZIP a GitHub"
    echo "URL del ZIP: $GITHUB_ZIP_URL"
    echo ""
    read -p "¿Quieres usar esta URL o cambiarla? (Enter para continuar, 'c' para cambiar): " -n 1 -r
    echo ""
    
    if [[ $REPLY =~ ^[Cc]$ ]]; then
        read -p "Introduce la URL del ZIP en GitHub: " GITHUB_ZIP_URL
    fi
    
    # Ejecutar instalación
    detect_os
    install_dependencies
    configure_firewall
    download_website
    
    if [ "$WEBSERVER" == "nginx" ]; then
        setup_nginx
    else
        setup_apache
    fi
    
    setup_https
    show_summary
}

# Ejecutar función principal
main
