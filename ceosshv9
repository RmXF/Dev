# Instalar BadVPN
install_badvpn() {
    if [[ "$INSTALL_BADVPN" != "y" ]]; then
        info "Saltando instalación de BadVPN..."
        return
    fi
    
    info "Instalando BadVPN..."
    
    cd /tmp
    git clone https://github.com/ambrop72/badvpn.git
    cd badvpn
    cmake -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1
    make
    make install
    
    # Crear servicio systemd
    cat > /etc/systemd/system/badvpn.service << EOF
[Unit]
Description=BadVPN UDP Gateway
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 1000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF

    systemctl daemon-reload
    systemctl enable badvpn
    systemctl start badvpn
    
    success "BadVPN instalado"
}

# Instalar WebSocket
install_websocket() {
    if [[ "$INSTALL_WEBSOCKET" != "y" ]]; then
        info "Saltando instalación de WebSocket..."
        return
    fi
    
    info "Instalando WebSocket proxy..."
    
    cat > /etc/systemd/system/ws-proxy.service << EOF
[Unit]
Description=WebSocket Proxy
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=$INSTALL_DIR
ExecStart=/usr/bin/node $INSTALL_DIR/websocket/server.js
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF

    mkdir -p $INSTALL_DIR/websocket
    
    cat > $INSTALL_DIR/websocket/server.js << 'EOF'
const WebSocket = require('ws');
const http = require('http');
const jwt = require('jsonwebtoken');

const server = http.createServer();
const wss = new WebSocket.Server({ server });

const clients = new Map();

wss.on('connection', (ws, req) => {
    const token = new URL(req.url, 'http://localhost').searchParams.get('token');
    
    try {
        const decoded = jwt.verify(token, 'JWT_SECRET_PLACEHOLDER');
        clients.set(ws, { userId: decoded.id, username: decoded.username });
        
        ws.on('message', (data) => {
            const message = JSON.parse(data);
            // Broadcast to all clients
            clients.forEach((client, clientWs) => {
                if (clientWs !== ws && clientWs.readyState === WebSocket.OPEN) {
                    clientWs.send(JSON.stringify(message));
                }
            });
        });
        
        ws.on('close', () => clients.delete(ws));
    } catch(e) {
        ws.close();
    }
});

server.listen(3002, () => {
    console.log('WebSocket server running on port 3002');
});
EOF

    cd $INSTALL_DIR/websocket
    npm init -y
    npm install ws jsonwebtoken
    
    systemctl daemon-reload
    systemctl enable ws-proxy
    systemctl start ws-proxy
    
    success "WebSocket instalado"
}

# Configurar Nginx
configure_nginx() {
    info "Configurando Nginx..."
    
    PHP_VERSION=$(php -r "echo PHP_MAJOR_VERSION . '.' . PHP_MINOR_VERSION;")
    
    cat > /etc/nginx/sites-available/ceo-ssh << EOF
server {
    listen $PANEL_PORT;
    listen [::]:$PANEL_PORT;
    server_name _;
    root $INSTALL_DIR;
    index index.php index.html;
    
    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/xml+rss application/json;
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    
    # Cache static files
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|woff|woff2|ttf|svg)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
    
    location / {
        try_files \$uri \$uri/ /index.php?\$args;
    }
    
    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/var/run/php/php${PHP_VERSION}-fpm.sock;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        include fastcgi_params;
    }
    
    # Deny access to hidden files
    location ~ /\. {
        deny all;
    }
    
    # Deny access to sensitive directories
    location ~ ^/(includes|api/config) {
        deny all;
    }
}
EOF
    
    ln -sf /etc/nginx/sites-available/ceo-ssh /etc/nginx/sites-enabled/
    rm -f /etc/nginx/sites-enabled/default
    nginx -t
    systemctl restart nginx
    systemctl restart php${PHP_VERSION}-fpm
    
    success "Nginx configurado"
}

# Configurar firewall
configure_firewall() {
    info "Configurando firewall..."
    
    ufw --force disable
    ufw default deny incoming
    ufw default allow outgoing
    
    # Puertos SSH
    ufw allow 22/tcp comment 'SSH'
    ufw allow 80/tcp comment 'HTTP Panel'
    ufw allow 443/tcp comment 'HTTPS'
    
    # Puertos VPN
    ufw allow 443/udp comment 'OpenVPN'
    ufw allow 1194/udp comment 'OpenVPN'
    ufw allow 7300/tcp comment 'Dropbear'
    ufw allow 7300/udp comment 'BadVPN'
    ufw allow 8000/tcp comment 'Stunnel'
    ufw allow 3128/tcp comment 'Squid'
    ufw allow 3002/tcp comment 'WebSocket'
    
    ufw --force enable
    
    # Configurar fail2ban
    cat > /etc/fail2ban/jail.local << EOF
[DEFAULT]
bantime = 3600
findtime = 600
maxretry = 5

[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = 3

[nginx-auth]
enabled = true
port = http,https
filter = nginx-auth
logpath = /var/log/nginx/error.log
maxretry = 5
EOF

    systemctl restart fail2ban
    
    success "Firewall configurado"
}

# Configurar cron jobs
setup_cron() {
    info "Configurando tareas programadas..."
    
    # Backup diario
    cat > /etc/cron.daily/ceo-ssh-backup << EOF
#!/bin/bash
mysqldump -u ceo_ssh -p$MYSQL_CEO_PASS ceo_ssh > /var/backups/ceo-ssh-\$(date +%Y%m%d).sql
find /var/backups -name "ceo-ssh-*.sql" -mtime +7 -delete
EOF
    chmod +x /etc/cron.daily/ceo-ssh-backup
    
    # Limpiar usuarios expirados diariamente
    cat > /etc/cron.daily/ceo-ssh-cleanup << EOF
#!/bin/bash
mysql -u ceo_ssh -p$MYSQL_CEO_PASS ceo_ssh -e "UPDATE ssh_tokens SET status = 'expired' WHERE expires_at < NOW() AND status = 'active'"
EOF
    chmod +x /etc/cron.daily/ceo-ssh-cleanup
    
    success "Tareas programadas configuradas"
}

