    # API de usuarios
    cat > $INSTALL_DIR/api/users.php << 'EOF'
<?php
header('Content-Type: application/json');
require_once '../includes/config.php';

if (!isLoggedIn()) {
    echo json_encode(['success' => false, 'error' => 'No autorizado']);
    exit;
}

$data = json_decode(file_get_contents('php://input'), true);
$action = $data['action'] ?? '';

if ($action === 'create') {
    $username = $data['username'];
    $password = $data['password'];
    $days = intval($data['days']);
    
    $check = shell_exec("id $username 2>/dev/null");
    if ($check) {
        echo json_encode(['success' => false, 'error' => 'Usuario ya existe']);
        exit;
    }
    
    $expire_date = date('Y-m-d', strtotime("+$days days"));
    shell_exec("useradd -m -s /bin/false -e $expire_date $username");
    shell_exec("echo \"$username:$password\" | chpasswd");
    
    $stmt = $conn->prepare("INSERT INTO ssh_tokens (username, password, expires_at, created_by) VALUES (?, ?, ?, ?)");
    $stmt->bind_param("sssi", $username, $password, $expire_date, $_SESSION['user_id']);
    
    if ($stmt->execute()) {
        addLog($_SESSION['user_id'], 'create_user', "Creado usuario: $username", $_SERVER['REMOTE_ADDR']);
        echo json_encode(['success' => true]);
    } else {
        echo json_encode(['success' => false, 'error' => 'Error en base de datos']);
    }
    exit;
}

if ($action === 'delete') {
    $user_id = $data['user_id'];
    
    $stmt = $conn->prepare("SELECT username FROM ssh_tokens WHERE id = ?");
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $result = $stmt->get_result();
    $user = $result->fetch_assoc();
    
    if ($user) {
        shell_exec("userdel -r -f " . $user['username']);
        $stmt = $conn->prepare("DELETE FROM ssh_tokens WHERE id = ?");
        $stmt->bind_param("i", $user_id);
        $stmt->execute();
        addLog($_SESSION['user_id'], 'delete_user', "Eliminado usuario: " . $user['username'], $_SERVER['REMOTE_ADDR']);
        echo json_encode(['success' => true]);
    } else {
        echo json_encode(['success' => false, 'error' => 'Usuario no encontrado']);
    }
    exit;
}

if ($action === 'extend') {
    $user_id = $data['user_id'];
    $days = intval($data['days']);
    
    $stmt = $conn->prepare("SELECT username, expires_at FROM ssh_tokens WHERE id = ?");
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $result = $stmt->get_result();
    $user = $result->fetch_assoc();
    
    if ($user) {
        $current_exp = $user['expires_at'];
        $new_exp = date('Y-m-d', strtotime("$current_exp + $days days"));
        shell_exec("usermod -e $new_exp " . $user['username']);
        
        $stmt = $conn->prepare("UPDATE ssh_tokens SET expires_at = ? WHERE id = ?");
        $stmt->bind_param("si", $new_exp, $user_id);
        $stmt->execute();
        
        addLog($_SESSION['user_id'], 'extend_user', "Extendido usuario: " . $user['username'] . " +$days días", $_SERVER['REMOTE_ADDR']);
        echo json_encode(['success' => true]);
    } else {
        echo json_encode(['success' => false, 'error' => 'Usuario no encontrado']);
    }
    exit;
}

echo json_encode(['success' => false, 'error' => 'Acción no válida']);
?>
EOF

