    echo "   ██████╗███████╗ ██████╗     ███████╗███████╗██╗  ██╗"
    echo "  ██╔════╝██╔════╝██╔═══██╗    ██╔════╝██╔════╝██║  ██║"
    echo "  ██║     █████╗  ██║   ██║    ███████╗███████╗███████║"
    echo "  ██║     ██╔══╝  ██║   ██║    ╚════██║╚════██║██╔══██║"
    echo "  ╚██████╗███████╗╚██████╔╝    ███████║███████║██║  ██║"
    echo "   ╚═════╝╚══════╝ ╚═════╝     ╚══════╝╚══════╝╚═╝  ╚═╝"
    echo -e "${NC}"
    echo -e "${GREEN}        PANEL DE CONTROL PROFESIONAL SSH${NC}"
    echo -e "${YELLOW}                   Versión ${PANEL_VERSION}${NC}"
    echo -e "${WHITE}        🚀 Instalación Automática Completa 🚀${NC}"
    echo ""
}

log() { echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a $LOG_FILE; }
error() { echo -e "${RED}❌ ERROR: $1${NC}" | tee -a $LOG_FILE; exit 1; }
success() { echo -e "${GREEN}✅ $1${NC}" | tee -a $LOG_FILE; }
info() { echo -e "${CYAN}ℹ️  $1${NC}" | tee -a $LOG_FILE; }
warning() { echo -e "${YELLOW}⚠️  $1${NC}" | tee -a $LOG_FILE; }

check_root() {
    if [ "$EUID" -ne 0 ]; then
        error "Por favor ejecuta como root (sudo ./install.sh)"
    fi
    success "Root verificados"
}

check_os() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS=$ID
        if [[ "$OS" == "ubuntu" ]] || [[ "$OS" == "debian" ]]; then
            success "Sistema operativo compatible: $OS"
        else
            error "Sistema no soportado. Usa Ubuntu o Debian"
        fi
    else
        error "No se pudo detectar el sistema operativo"
    fi
}

ask_config() {
    echo ""
    echo -e "${PURPLE}════════════════════════════════════════════════════${NC}"
    echo -e "${WHITE}       CONFIGURACIÓN DEL PANEL CEO SSH${NC}"
    echo -e "${PURPLE}════════════════════════════════════════════════════${NC}"
    echo ""
    
    read -p "$(echo -e ${CYAN}👤 Usuario administrador: ${NC})" ADMIN_USER
    while [[ -z "$ADMIN_USER" ]]; do
        read -p "$(echo -e ${RED}⚠️ Usuario requerido: ${NC})" ADMIN_USER
    done
    
    read -p "$(echo -e ${CYAN}📧 Email administrador: ${NC})" ADMIN_EMAIL
    while [[ -z "$ADMIN_EMAIL" ]]; do
        read -p "$(echo -e ${RED}⚠️ Email requerido: ${NC})" ADMIN_EMAIL
    done
    
    read -s -p "$(echo -e ${CYAN}🔑 Contraseña administrador: ${NC})" ADMIN_PASS
    echo ""
    while [[ ${#ADMIN_PASS} -lt 6 ]]; do
        read -s -p "$(echo -e ${RED}⚠️ Mínimo 6 caracteres: ${NC})" ADMIN_PASS
        echo ""
    done
    
    read -s -p "$(echo -e ${CYAN}✅ Confirmar contraseña: ${NC})" ADMIN_PASS_CONFIRM
    echo ""
    if [[ "$ADMIN_PASS" != "$ADMIN_PASS_CONFIRM" ]]; then
        error "Las contraseñas no coinciden"
    fi
    
    read -p "$(echo -e ${CYAN}🌐 Puerto del panel [80]: ${NC})" PANEL_PORT_INPUT
    PANEL_PORT=${PANEL_PORT_INPUT:-80}
    
    echo ""
    success "Configuración guardada"
}

generate_passwords() {
    MYSQL_ROOT_PASS=$(openssl rand -base64 16)
    MYSQL_CEO_PASS=$(openssl rand -base64 16)
}

stop_services() {
    info "Verificando servicios en puerto 80..."
    if systemctl is-active --quiet apache2; then
        systemctl stop apache2 && systemctl disable apache2
        success "Apache detenido"
    fi
    if systemctl is-active --quiet nginx; then
        systemctl stop nginx && systemctl disable nginx
        success "Nginx detenido"
    fi
    success "Puerto 80 liberado"
}

install_dependencies() {
    info "Instalando dependencias..."
    apt-get update -y
    apt-get install -y curl wget git unzip zip nginx mariadb-server mariadb-client \
        php8.2 php8.2-cli php8.2-fpm php8.2-mysql php8.2-mysqli php8.2-pdo \
        php8.2-curl php8.2-json php8.2-mbstring php8.2-xml php8.2-zip php8.2-gd \
        php8.2-bcmath ufw fail2ban openssl
    success "Dependencias instaladas"
}

configure_mysql() {
    info "Configurando MySQL..."
    systemctl enable mariadb
    systemctl start mariadb
    
    mysql -e "SET PASSWORD FOR 'root'@'localhost' = PASSWORD('$MYSQL_ROOT_PASS');" 2>/dev/null || true
    mysql -e "DELETE FROM mysql.user WHERE User='';" 2>/dev/null || true
    mysql -e "CREATE DATABASE IF NOT EXISTS ceo_ssh CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" 2>/dev/null
    mysql -e "CREATE USER IF NOT EXISTS 'ceo_ssh'@'localhost' IDENTIFIED BY '$MYSQL_CEO_PASS';" 2>/dev/null
    mysql -e "GRANT ALL PRIVILEGES ON ceo_ssh.* TO 'ceo_ssh'@'localhost';" 2>/dev/null
    mysql -e "FLUSH PRIVILEGES;" 2>/dev/null
    
    success "MySQL configurado"
}

create_directories() {
    info "Creando directorios..."
    mkdir -p $INSTALL_DIR/{assets/css,assets/js,assets/img,includes,api,pages}
    success "Directorios creados"
}

# Crear configuración de base de datos
create_db_config() {
    cat > $INSTALL_DIR/includes/config.php << 'EOF'
<?php
session_start();
header('Content-Type: text/html; charset=utf-8');
date_default_timezone_set('America/Mexico_City');

define('DB_HOST', 'localhost');
define('DB_USER', 'DB_USER_PLACEHOLDER');
define('DB_PASS', 'DB_PASS_PLACEHOLDER');
define('DB_NAME', 'ceo_ssh');
define('PANEL_NAME', 'CEO SSH');
define('PANEL_VERSION', '1.0.0');

$conn = new mysqli(DB_HOST, DB_USER, DB_PASS, DB_NAME);
if ($conn->connect_error) {
    die("Error de conexión: " . $conn->connect_error);
}
$conn->set_charset("utf8mb4");

function isLoggedIn() {
    return isset($_SESSION['user_id']) && isset($_SESSION['logged_in']) && $_SESSION['logged_in'] === true;
}

function requireLogin() {
    if (!isLoggedIn()) {
        header('Location: /login');
        exit;
    }
}

function encryptPassword($password) {
    return password_hash($password, PASSWORD_DEFAULT);
}

function verifyPassword($password, $hash) {
    return password_verify($password, $hash);
}

function addLog($user_id, $action, $details, $ip) {
    global $conn;
    $stmt = $conn->prepare("INSERT INTO logs (user_id, action, details, ip_address) VALUES (?, ?, ?, ?)");
    $stmt->bind_param("isss", $user_id, $action, $details, $ip);
    $stmt->execute();
}

function getSystemStats() {
    $load = sys_getloadavg();
    $total_users = shell_exec("cat /etc/passwd | grep '/home' | wc -l");
    $online_users = shell_exec("ps aux | grep -E 'sshd|dropbear' | grep -v grep | wc -l");
    $disk_usage = shell_exec("df -h / | awk 'NR==2 {print $5}' | sed 's/%//'");
    
    return [
        'load' => $load[0],
        'total_users' => trim($total_users),
        'online_users' => trim($online_users),
        'disk_usage' => trim($disk_usage)
    ];
}
?>
EOF
    sed -i "s/DB_USER_PLACEHOLDER/ceo_ssh/g" $INSTALL_DIR/includes/config.php
    sed -i "s/DB_PASS_PLACEHOLDER/$MYSQL_CEO_PASS/g" $INSTALL_DIR/includes/config.php
}

