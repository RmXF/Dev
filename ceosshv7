# Crear JavaScript principal
create_js() {
    cat > $INSTALL_DIR/assets/js/app.js << 'EOF'
let currentTheme = localStorage.getItem('theme') || 'dark';

function setTheme(theme) {
    if (theme === 'light') {
        document.body.classList.add('light');
    } else {
        document.body.classList.remove('light');
    }
    localStorage.setItem('theme', theme);
    currentTheme = theme;
}

function toggleTheme() {
    setTheme(currentTheme === 'dark' ? 'light' : 'dark');
}

function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const mainContent = document.getElementById('mainContent');
    sidebar.classList.toggle('collapsed');
    mainContent.classList.toggle('expanded');
}

function openModal(modalId) {
    document.getElementById(modalId).classList.add('show');
}

function closeModal(modalId) {
    document.getElementById(modalId).classList.remove('show');
}

async function fetchAPI(endpoint, options = {}) {
    const response = await fetch(endpoint, {
        headers: { 'Content-Type': 'application/json' },
        ...options
    });
    return response.json();
}

async function createUser() {
    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;
    const days = document.getElementById('days').value;
    
    if (!username || !password) {
        alert('Complete todos los campos');
        return;
    }
    
    const response = await fetchAPI('/api/users.php', {
        method: 'POST',
        body: JSON.stringify({ username, password, days, action: 'create' })
    });
    
    if (response.success) {
        alert('Usuario creado exitosamente');
        closeModal('createUserModal');
        location.reload();
    } else {
        alert('Error: ' + response.error);
    }
}

async function deleteUser(username, userId) {
    if (confirm('¿Eliminar usuario ' + username + '?')) {
        const response = await fetchAPI('/api/users.php', {
            method: 'POST',
            body: JSON.stringify({ user_id: userId, action: 'delete' })
        });
        
        if (response.success) {
            location.reload();
        } else {
            alert('Error al eliminar');
        }
    }
}

async function extendUser(userId) {
    const days = prompt('¿Cuántos días agregar?', '30');
    if (days) {
        const response = await fetchAPI('/api/users.php', {
            method: 'POST',
            body: JSON.stringify({ user_id: userId, days, action: 'extend' })
        });
        
        if (response.success) {
            alert('Usuario extendido ' + days + ' días');
            location.reload();
        } else {
            alert('Error al extender');
        }
    }
}

async function loadStats() {
    const stats = await fetchAPI('/api/stats.php');
    if (stats.success) {
        document.getElementById('totalUsers').innerText = stats.data.total_users;
        document.getElementById('activeTokens').innerText = stats.data.active_tokens;
        document.getElementById('onlineUsers').innerText = stats.data.online_users;
        document.getElementById('serverLoad').innerHTML = stats.data.load + ' <small>avg</small>';
        document.getElementById('diskUsage').innerText = stats.data.disk_usage + '%';
    }
}

setInterval(loadStats, 30000);
document.addEventListener('DOMContentLoaded', () => {
    setTheme(currentTheme);
    loadStats();
});
EOF
}

