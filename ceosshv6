# Detener servicios que usan puerto 80
stop_services() {
    info "Verificando servicios en puerto 80..."
    
    if systemctl is-active --quiet apache2; then
        warning "Apache está corriendo en puerto 80, deteniendo..."
        systemctl stop apache2
        systemctl disable apache2
        success "Apache detenido y deshabilitado"
    fi
    
    if systemctl is-active --quiet nginx; then
        warning "Nginx está corriendo en puerto 80, deteniendo..."
        systemctl stop nginx
        systemctl disable nginx
        success "Nginx detenido y deshabilitado"
    fi
    
    PID=$(lsof -ti:80 2>/dev/null || true)
    if [ ! -z "$PID" ]; then
        warning "Matando procesos en puerto 80..."
        kill -9 $PID 2>/dev/null || true
        success "Procesos terminados"
    fi
    
    success "Puerto 80 liberado"
}

